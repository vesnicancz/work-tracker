# Auto detect text files and ensure CRLF line endings in working directory
* text=auto eol=crlf

# Explicit text files
*.cs text eol=crlf
*.csproj text eol=crlf
*.sln text eol=crlf
*.xaml text eol=crlf
*.axaml text eol=crlf
*.json text eol=crlf
*.xml text eol=crlf
*.md text eol=crlf
*.resx text eol=crlf
*.props text eol=crlf
*.targets text eol=crlf

# Shell scripts always LF
*.sh text eol=lf

# Binary files
*.png binary
*.ico binary
*.dll binary
