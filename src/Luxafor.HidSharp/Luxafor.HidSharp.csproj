<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- Clear single TargetFramework from Directory.Build.props to enable multi-targeting -->
    <TargetFramework />
    <TargetFrameworks>netstandard2.0;net8.0</TargetFrameworks>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageId>Luxafor.HidSharp</PackageId>
    <Description>Luxafor LED device control library using HidSharp. Supports static color, fade, strobe, wave, built-in patterns, and per-LED targeting for Luxafor Flag and Bluetooth Pro devices.</Description>
    <Authors>vesnicancz</Authors>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>luxafor;hid;led;usb;bluetooth</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="HidSharp" Version="2.6.4" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Memory" Version="4.6.3" />
    <PackageReference Include="Microsoft.Bcl.HashCode" Version="6.0.0" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <PropertyGroup>
    <MinVerSkip>true</MinVerSkip>
  </PropertyGroup>

</Project>
