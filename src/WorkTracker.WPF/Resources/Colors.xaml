<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Colors -->
    <Color x:Key="PrimaryColor">#673AB7</Color>
    <Color x:Key="PrimaryLightColor">#9575CD</Color>
    <Color x:Key="PrimaryDarkColor">#512DA8</Color>

    <!-- Accent Colors -->
    <Color x:Key="AccentColor">#CDDC39</Color>
    <Color x:Key="AccentLightColor">#DCE775</Color>
    <Color x:Key="AccentDarkColor">#C0CA33</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessColor">#4CAF50</Color>
    <Color x:Key="WarningColor">#FF9800</Color>
    <Color x:Key="ErrorColor">#F44336</Color>
    <Color x:Key="InfoColor">#2196F3</Color>

    <!-- Work Entry Status Colors -->
    <Color x:Key="ActiveWorkColor">#4CAF50</Color>
    <Color x:Key="CompletedWorkColor">#757575</Color>

    <!-- Title Bar Gradient Colors -->
    <Color x:Key="TitleBarGradientStartColor">#673AB7</Color>
    <Color x:Key="TitleBarGradientEndColor">#00BCD4</Color>
    <!--<Color x:Key="TitleBarGradientEndColor">#2196F3</Color>-->

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLightColor}" />
    <SolidColorBrush x:Key="PrimaryDarkBrush" Color="{StaticResource PrimaryDarkColor}" />

    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentLightBrush" Color="{StaticResource AccentLightColor}" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="{StaticResource AccentDarkColor}" />

    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource ErrorColor}" />
    <SolidColorBrush x:Key="InfoBrush" Color="{StaticResource InfoColor}" />

    <SolidColorBrush x:Key="ActiveWorkBrush" Color="{StaticResource ActiveWorkColor}" />
    <SolidColorBrush x:Key="CompletedWorkBrush" Color="{StaticResource CompletedWorkColor}" />

    <!-- Pomodoro Phase Colors -->
    <Color x:Key="PomodoroWorkBgColor">#2a1e1e</Color>
    <Color x:Key="PomodoroWorkBorderColor">#5c3d3d</Color>
    <Color x:Key="PomodoroBreakBgColor">#1e2a1e</Color>
    <Color x:Key="PomodoroBreakBorderColor">#3d5c3d</Color>
    <Color x:Key="PomodoroLongBreakBgColor">#1e222a</Color>
    <Color x:Key="PomodoroLongBreakBorderColor">#3d4a5c</Color>

    <SolidColorBrush x:Key="PomodoroWorkBgBrush" Color="{StaticResource PomodoroWorkBgColor}" />
    <SolidColorBrush x:Key="PomodoroWorkBorderBrush" Color="{StaticResource PomodoroWorkBorderColor}" />
    <SolidColorBrush x:Key="PomodoroBreakBgBrush" Color="{StaticResource PomodoroBreakBgColor}" />
    <SolidColorBrush x:Key="PomodoroBreakBorderBrush" Color="{StaticResource PomodoroBreakBorderColor}" />
    <SolidColorBrush x:Key="PomodoroLongBreakBgBrush" Color="{StaticResource PomodoroLongBreakBgColor}" />
    <SolidColorBrush x:Key="PomodoroLongBreakBorderBrush" Color="{StaticResource PomodoroLongBreakBorderColor}" />

    <!-- Gradient Brushes -->
    <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="{StaticResource TitleBarGradientStartColor}" Offset="0" />
        <GradientStop Color="{StaticResource TitleBarGradientEndColor}" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>