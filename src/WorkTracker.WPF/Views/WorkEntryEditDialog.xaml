<Window x:Class="WorkTracker.WPF.Views.WorkEntryEditDialog"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		xmlns:viewmodels="clr-namespace:WorkTracker.WPF.ViewModels"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		d:DataContext="{d:DesignInstance Type=viewmodels:WorkEntryEditViewModel}"
		mc:Ignorable="d"
		Title="{Binding DialogTitle}"
		Height="580"
		Width="500"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ResizeMode="NoResize"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40"
					 ResizeBorderThickness="0"
					 GlassFrameThickness="0"
					 CornerRadius="0"
					 UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
		<converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
		<converters:TimeSpanToDateTimeConverter x:Key="TimeSpanToDateTimeConverter" />
	</Window.Resources>

	<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
			BorderThickness="1"
			CornerRadius="8"
			Margin="15"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black"
							  Opacity="0.3"
							  BlurRadius="20"
							  ShadowDepth="8"
							  Direction="315" />
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- Title Bar -->
			<materialDesign:ColorZone Grid.Row="0"
									 Padding="16,8"
									 CornerRadius="8,8,0,0"
									 materialDesign:ElevationAssist.Elevation="Dp4"
									 MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
									 Background="{StaticResource TitleBarGradientBrush}">
			<DockPanel>
				<!-- Close Button -->
				<Button x:Name="CloseButton"
					   DockPanel.Dock="Right"
					   Style="{StaticResource MaterialDesignFlatButton}"
					   Width="40"
					   Height="32"
					   Padding="0"
					   ToolTip="{markup:Localize Close}"
				   Foreground="White"
					   WindowChrome.IsHitTestVisibleInChrome="True">
					<materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
				</Button>

				<!-- Title -->
				<TextBlock Text="{Binding DialogTitle}"
						  FontSize="18"
						  FontWeight="SemiBold"
						  VerticalAlignment="Center"
						  Foreground="White" />
			</DockPanel>
		</materialDesign:ColorZone>

		<!-- Content -->
		<Grid Grid.Row="1" Margin="24"
			  FocusManager.FocusedElement="{Binding ElementName=TicketIdTextBox}">
			<Grid.RowDefinitions>
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<!-- Form -->
			<StackPanel Grid.Row="0">
				<!-- Ticket ID -->
				<TextBox x:Name="TicketIdTextBox"
					Text="{Binding TicketId, UpdateSourceTrigger=PropertyChanged}"
					Style="{StaticResource InputTextBoxStyle}"
					materialDesign:HintAssist.Hint="{markup:Localize TicketIdOptional}"
					materialDesign:HintAssist.IsFloating="True"
					MaxLength="50" />

				<!-- Description -->
				<TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
					Style="{StaticResource InputTextBoxStyle}"
					materialDesign:HintAssist.Hint="{markup:Localize DescriptionOptional}"
					materialDesign:HintAssist.IsFloating="True"
					MaxLength="500"
					AcceptsReturn="True"
					TextWrapping="Wrap"
					MinLines="2"
					MaxLines="4" />

				<!-- Start Date/Time -->
				<TextBlock Text="{markup:Localize StartTime}"
					  FontWeight="Medium"
					  Margin="0,16,0,8" />
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="16" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<DatePicker Grid.Column="0"
						   SelectedDate="{Binding StartDate}"
						   Style="{StaticResource InputDatePickerStyle}"
						   materialDesign:HintAssist.Hint="{markup:Localize Date}"
						   Margin="0" />

					<materialDesign:TimePicker Grid.Column="2"
										  SelectedTime="{Binding StartTime, Converter={StaticResource TimeSpanToDateTimeConverter}}"
										  Is24Hours="True"
										  WithSeconds="False"
										  materialDesign:HintAssist.Hint="{markup:Localize Time}"
										  Margin="0,8" />
				</Grid>

				<!-- Has End Time Checkbox -->
				<CheckBox IsChecked="{Binding HasEndTime}"
					 Content="{markup:Localize SetEndTime}"
					 Margin="0,16,0,8" />

				<!-- End Date/Time -->
				<StackPanel Visibility="{Binding HasEndTime, Converter={StaticResource BoolToVisibilityConverter}}">
					<TextBlock Text="{markup:Localize EndTime}"
						  FontWeight="Medium"
						  Margin="0,8,0,8" />
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="16" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<DatePicker Grid.Column="0"
							   SelectedDate="{Binding EndDate}"
							   Style="{StaticResource InputDatePickerStyle}"
							   materialDesign:HintAssist.Hint="{markup:Localize Date}"
							   Margin="0" />

						<materialDesign:TimePicker Grid.Column="2"
											  SelectedTime="{Binding EndTime, Converter={StaticResource TimeSpanToDateTimeConverter}}"
											  Is24Hours="True"
											  WithSeconds="False"
											  materialDesign:HintAssist.Hint="{markup:Localize Time}"
											  Margin="0,8" />
					</Grid>
				</StackPanel>
			</StackPanel>

			<!-- Validation Error -->
			<TextBlock Grid.Row="1"
				  Text="{Binding ValidationError}"
				  Foreground="{StaticResource ErrorBrush}"
				  FontWeight="Medium"
				  TextWrapping="Wrap"
				  Margin="0,16,0,0"
				  Visibility="{Binding ValidationError, Converter={StaticResource NullToVisibilityConverter}}" />

			<!-- Buttons -->
			<StackPanel Grid.Row="2"
				   Orientation="Horizontal"
				   HorizontalAlignment="Right"
				   Margin="0,24,0,0">
				<Button Content="{markup:Localize Cancel}"
				   Command="{Binding CancelCommand}"
				   Style="{StaticResource SecondaryButtonStyle}"
				   Width="100"
				   Margin="0,0,8,0" />
				<Button Content="{markup:Localize Save}"
				   Command="{Binding SaveCommand}"
				   Style="{StaticResource PrimaryButtonStyle}"
				   Width="100"
				   IsDefault="True" />
			</StackPanel>
		</Grid>
	</Grid>
	</Border>
</Window>