<Window x:Class="WorkTracker.WPF.Views.SubmitWorklogDialog"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		xmlns:selectors="clr-namespace:WorkTracker.WPF.Selectors"
		xmlns:viewmodels="clr-namespace:WorkTracker.WPF.ViewModels"
		d:DataContext="{d:DesignInstance Type=viewmodels:SubmitWorklogViewModel}"
		mc:Ignorable="d"
		Title="{Binding DialogTitle}"
		Height="1000"
		Width="900"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ResizeMode="CanResize"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40"
					 ResizeBorderThickness="5"
					 GlassFrameThickness="0"
					 CornerRadius="0"
					 UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />

		<!-- Date Header Template -->
		<DataTemplate x:Key="DateHeaderTemplate">
			<StackPanel Margin="0,8,0,4">
				<TextBlock Text="{Binding DateDisplay}"
						   FontWeight="SemiBold"
						   FontSize="14"
						   Margin="0,0,0,8"
						   Foreground="{StaticResource PrimaryBrush}" />
				<Separator Margin="0,0,0,0" />
			</StackPanel>
		</DataTemplate>

		<!-- Work Entry Template - Simplified for performance -->
		<DataTemplate x:Key="WorkEntryTemplate">
			<Border Margin="0,2" CornerRadius="2" Padding="0"
					ToolTip="{Binding ErrorMessage}">
				<Border.Style>
					<Style TargetType="Border">
						<Setter Property="Background" Value="Transparent" />
						<Setter Property="BorderThickness" Value="0" />
						<Style.Triggers>
							<DataTrigger Binding="{Binding HasError}" Value="True">
								<Setter Property="Background" Value="#20FF4444" />
								<Setter Property="BorderBrush" Value="#60FF4444" />
								<Setter Property="BorderThickness" Value="1" />
							</DataTrigger>
						</Style.Triggers>
					</Style>
				</Border.Style>
				<Grid>
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="120" />
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="85" />
						<ColumnDefinition Width="85" />
						<ColumnDefinition Width="55" />
					</Grid.ColumnDefinitions>

					<TextBox Grid.Column="0"
							 Text="{Binding TicketId, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
							 materialDesign:HintAssist.Hint="{markup:Localize Ticket}"
							 FontWeight="Medium"
							 VerticalAlignment="Center"
							 BorderBrush="#CCCCCC"
							 BorderThickness="1"
							 Padding="6,4"
							 Margin="0,0,4,0" />

					<TextBox Grid.Column="1"
							 Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
							 VerticalAlignment="Center"
							 BorderBrush="#CCCCCC"
							 BorderThickness="1"
							 Padding="6,4"
							 Margin="4,0" />

					<TextBox Grid.Column="2"
							 Text="{Binding StartTimeDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
							 VerticalAlignment="Center"
							 BorderBrush="#CCCCCC"
							 BorderThickness="1"
							 Padding="6,4"
							 Margin="4,0,4,0" />

					<TextBox Grid.Column="3"
							 Text="{Binding EndTimeDisplay, Mode=TwoWay, UpdateSourceTrigger=LostFocus}"
							 VerticalAlignment="Center"
							 BorderBrush="#CCCCCC"
							 BorderThickness="1"
							 Padding="6,4"
							 Margin="4,0,4,0" />

					<TextBlock Grid.Column="4"
							   Text="{Binding DurationDisplay, Mode=OneWay}"
							   FontWeight="Medium"
							   HorizontalAlignment="Right"
							   VerticalAlignment="Center"
							   Margin="4,0,0,0" />
				</Grid>
			</Border>
		</DataTemplate>

		<!-- Template Selector -->
		<selectors:WorklogPreviewItemTemplateSelector x:Key="WorklogTemplateSelector"
													   DateHeaderTemplate="{StaticResource DateHeaderTemplate}"
													   WorkEntryTemplate="{StaticResource WorkEntryTemplate}" />
	</Window.Resources>

	<Border BorderBrush="#CCCCCC"
			BorderThickness="1"
			CornerRadius="8"
			Margin="15"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black"
							  Opacity="0.3"
							  BlurRadius="20"
							  ShadowDepth="8"
							  Direction="315" />
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- Title Bar -->
			<materialDesign:ColorZone Grid.Row="0"
									 Padding="16,8"
									 CornerRadius="8,8,0,0"
									 materialDesign:ElevationAssist.Elevation="Dp4"
									 MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
									 Background="{StaticResource TitleBarGradientBrush}">
				<DockPanel>
					<!-- Close Button -->
					<Button x:Name="CloseButton"
					   DockPanel.Dock="Right"
					   Style="{StaticResource MaterialDesignFlatButton}"
					   Width="40"
					   Height="32"
					   Padding="0"
					   Foreground="White"
					   ToolTip="{markup:Localize Close}"
					   WindowChrome.IsHitTestVisibleInChrome="True">
						<materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
					</Button>

					<!-- Title -->
					<TextBlock Text="{Binding DialogTitle}"
						  FontSize="18"
						  FontWeight="SemiBold"
						  VerticalAlignment="Center"
						  Foreground="White" />
				</DockPanel>
			</materialDesign:ColorZone>

			<!-- Content -->
			<Grid Grid.Row="1" Margin="24">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
					<RowDefinition Height="Auto" />
					<RowDefinition Height="Auto" />
				</Grid.RowDefinitions>

				<!-- Options -->
				<Grid Grid.Row="0" Margin="0,0,0,16">
					<Grid.ColumnDefinitions>
						<ColumnDefinition Width="*" />
						<ColumnDefinition Width="24" />
						<ColumnDefinition Width="*" />
					</Grid.ColumnDefinitions>

					<!-- Left column: Date and Checkbox -->
					<StackPanel Grid.Column="0">
						<DatePicker SelectedDate="{Binding SelectedDate}"
							   Style="{StaticResource InputDatePickerStyle}"
							   materialDesign:HintAssist.Hint="{markup:Localize Date}"
							   HorizontalAlignment="Stretch"
							   Margin="0,0,0,4" />

						<CheckBox IsChecked="{Binding IsWeekly}"
							 Content="{markup:Localize SubmitEntireWeek}"
							 Margin="0" />
					</StackPanel>

					<!-- Right column: Provider Selection -->
					<StackPanel Grid.Column="2" VerticalAlignment="Top">
						<ComboBox ItemsSource="{Binding AvailableProviders}"
							 SelectedItem="{Binding SelectedProvider}"
							 DisplayMemberPath="Name"
							 materialDesign:HintAssist.Hint="{markup:Localize SubmitTo}"
							 HorizontalAlignment="Stretch"
							 Style="{StaticResource MaterialDesignOutlinedComboBox}" />
					</StackPanel>
				</Grid>

				<!-- Preview List -->
				<Border Grid.Row="1"
			   BorderBrush="#CCCCCC"
			   BorderThickness="1"
			   CornerRadius="4"
			   Padding="8">
					<Grid>
						<!-- Loading Indicator -->
						<StackPanel HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
							<ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
								Value="0"
								IsIndeterminate="True"
								Width="48"
								Height="48" />
							<TextBlock Text="{markup:Localize LoadingPreview}"
							 Margin="0,16,0,0"
							 HorizontalAlignment="Center" />
						</StackPanel>

						<!-- Preview Items -->
						<ListBox ItemsSource="{Binding PreviewItems}"
							 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}"
							 VirtualizingPanel.IsVirtualizing="True"
							 VirtualizingPanel.VirtualizationMode="Recycling"
							 VirtualizingPanel.CacheLength="20,20"
							 VirtualizingPanel.CacheLengthUnit="Item"
							 ScrollViewer.CanContentScroll="True"
							 BorderThickness="0"
							 Background="Transparent"
							 HorizontalContentAlignment="Stretch">
							<ListBox.ItemContainerStyle>
								<Style TargetType="ListBoxItem">
									<Setter Property="Padding" Value="0" />
									<Setter Property="Margin" Value="0" />
									<Setter Property="Template">
										<Setter.Value>
											<ControlTemplate TargetType="ListBoxItem">
												<ContentPresenter />
											</ControlTemplate>
										</Setter.Value>
									</Setter>
								</Style>
							</ListBox.ItemContainerStyle>
							<ListBox.ItemTemplateSelector>
								<StaticResource ResourceKey="WorklogTemplateSelector" />
							</ListBox.ItemTemplateSelector>
						</ListBox>
					</Grid>
				</Border>

				<!-- Summary -->
				<Border Grid.Row="2"
			   Background="{DynamicResource MaterialDesign.Brush.Background.Light}"
			   CornerRadius="4"
			   Padding="16"
			   Margin="0,16,0,0">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>

						<StackPanel Grid.Column="0">
							<TextBlock Text="{Binding StatusMessage}"
							 FontSize="14"
							 TextWrapping="Wrap" />
						</StackPanel>

						<StackPanel Grid.Column="1">
							<TextBlock Text="{markup:Localize TotalTime}"
							 FontSize="12"
							 Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
							 HorizontalAlignment="Right" />
							<TextBlock Text="{Binding TotalTimeDisplay}"
							 FontSize="20"
							 FontWeight="Bold"
							 Foreground="{StaticResource PrimaryBrush}"
							 HorizontalAlignment="Right" />
						</StackPanel>
					</Grid>
				</Border>

				<!-- Buttons -->
				<DockPanel Grid.Row="3" Margin="0,24,0,0">
					<!-- Reset button on the left -->
					<Button Content="{markup:Localize Reset}"
					   Command="{Binding ResetCommand}"
					   Style="{StaticResource MaterialDesignOutlinedButton}"
					   Width="100"
					   DockPanel.Dock="Left"
					   ToolTip="{markup:Localize RestoreOriginalValues}" />

					<!-- Cancel and Submit buttons on the right -->
					<StackPanel Orientation="Horizontal"
						   HorizontalAlignment="Right">
						<Button Content="{markup:Localize Close}"
					   Command="{Binding CancelCommand}"
					   Style="{StaticResource SecondaryButtonStyle}"
					   Width="100"
					   Margin="0,0,8,0" />
						<Button Command="{Binding RetryFailedCommand}"
						   Style="{StaticResource WarningButtonStyle}"
						   Width="140"
						   Margin="0,0,8,0"
						   FontWeight="SemiBold"
						   Content="{markup:Localize RetryFailed}"
						   Visibility="{Binding HasFailedItems, Converter={StaticResource BoolToVisibilityConverter}}" />
						<Button Command="{Binding SendCommand}"
					   Style="{StaticResource PrimaryButtonStyle}"
					   Width="120">
							<Button.Content>
								<StackPanel Orientation="Horizontal">
									<ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
										Value="0"
										IsIndeterminate="True"
										Width="16"
										Height="16"
										Margin="0,0,8,0"
										Visibility="{Binding IsSending, Converter={StaticResource BoolToVisibilityConverter}}" />
									<TextBlock>
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Text" Value="{markup:Localize Submit}" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsSending}" Value="True">
														<Setter Property="Text" Value="{markup:Localize Submitting}" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>
								</StackPanel>
							</Button.Content>
						</Button>
					</StackPanel>
				</DockPanel>
			</Grid>
		</Grid>
	</Border>
</Window>