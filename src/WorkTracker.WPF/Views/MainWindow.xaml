<Window x:Class="WorkTracker.WPF.Views.MainWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		xmlns:viewmodels="clr-namespace:WorkTracker.WPF.ViewModels"
		d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
		mc:Ignorable="d"
		Title="{markup:Localize AppTitle}"
		Height="800"
		Width="1200"
		MinHeight="600"
		MinWidth="800"
		WindowStartupLocation="CenterScreen"
		WindowStyle="None"
		ResizeMode="CanResize"
		ShowInTaskbar="False"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13"
		TextOptions.TextFormattingMode="Ideal"
		TextOptions.TextRenderingMode="Auto">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="48"
					 ResizeBorderThickness="5"
					 GlassFrameThickness="0"
					 CornerRadius="0"
					 UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<converters:TimeSpanToStringConverter x:Key="TimeSpanToStringConverter" />
		<converters:DateTimeToStringConverter x:Key="DateTimeToStringConverter" />
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
		<converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
	</Window.Resources>

	<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
			BorderThickness="1"
			CornerRadius="8"
			Margin="15"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black"
							  Opacity="0.3"
							  BlurRadius="20"
							  ShadowDepth="8"
							  Direction="315" />
		</Border.Effect>
		<materialDesign:DialogHost Identifier="RootDialog">
			<Grid>
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto" />
					<RowDefinition Height="*" />
				</Grid.RowDefinitions>

				<!-- Header / Title Bar -->
				<materialDesign:ColorZone Grid.Row="0"
										  Padding="16,8"
										  CornerRadius="8,8,0,0"
										  MouseDoubleClick="TitleBar_MouseDoubleClick"
										  materialDesign:ElevationAssist.Elevation="Dp4"
										  Background="{StaticResource TitleBarGradientBrush}">
					<DockPanel>
						<!-- Window Control Buttons -->
						<Button x:Name="CloseButton"
						   DockPanel.Dock="Right"
						   Style="{StaticResource MaterialDesignFlatButton}"
						   Width="40"
						   Height="32"
						   Padding="0"
						   Foreground="White"
						   ToolTip="{markup:Localize Close}"
						   WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Close" Width="20" Height="20" />
						</Button>

						<Button DockPanel.Dock="Right"
						   Style="{StaticResource MaterialDesignFlatButton}"
						   Width="40"
						   Height="32"
						   Padding="0"
						   Foreground="White"
						   ToolTip="{markup:Localize Settings}"
						   Command="{Binding OpenSettingsCommand}"
						   WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Cog" Width="20" Height="20" />
						</Button>

						<!-- Title -->
						<StackPanel Orientation="Horizontal">
							<materialDesign:PackIcon Kind="ClockTimeFourOutline"
												Width="32"
												Height="32"
												VerticalAlignment="Center"
												Margin="0,0,8,0"
												Foreground="White" />
							<TextBlock Text="{markup:Localize WorkTracker}"
								  FontSize="24"
								  FontWeight="SemiBold"
								  VerticalAlignment="Center"
								  Foreground="White" />
						</StackPanel>
					</DockPanel>
				</materialDesign:ColorZone>

				<!-- Main Content -->
				<ScrollViewer Grid.Row="1"
						 VerticalScrollBarVisibility="Auto"
						 Padding="16">
					<Grid>
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="2*" MinWidth="300" />
							<ColumnDefinition Width="16" />
							<ColumnDefinition Width="5*" MinWidth="500" />
						</Grid.ColumnDefinitions>

						<!-- Left Panel: Active Work & Input -->
						<StackPanel Grid.Column="0">

							<!-- Active Work Card -->
							<materialDesign:Card Style="{StaticResource CardStyle}"
										   Visibility="{Binding IsTracking, Converter={StaticResource BoolToVisibilityConverter}}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<!-- Header -->
									<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
										<materialDesign:PackIcon Kind="Play"
														   Width="24"
														   Height="24"
														   Foreground="{StaticResource ActiveWorkBrush}"
														   VerticalAlignment="Center"
														   Margin="0,0,8,0" />
										<TextBlock Text="{markup:Localize ActiveWork}"
											 Style="{StaticResource SubheaderTextStyle}"
											 Foreground="{StaticResource ActiveWorkBrush}"
											 Margin="0" />
									</StackPanel>

									<!-- Timer -->
									<TextBlock Grid.Row="1"
										 Text="{Binding ElapsedTime}"
										 Style="{StaticResource TimerTextStyle}"
										 Margin="0,0,0,16" />

									<!-- Ticket & Description -->
									<StackPanel Grid.Row="2" Margin="0,0,0,16">
										<TextBlock Text="{markup:Localize Ticket}"
											 FontSize="12"
											 Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											 Margin="0,0,0,4" />
										<TextBlock Text="{Binding ActiveTicketDisplay}"
											 FontSize="16"
											 FontWeight="Medium"
											 Margin="0,0,0,12" />

										<TextBlock Text="{markup:Localize Description}"
											 FontSize="12"
											 Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											 Margin="0,0,0,4" />
										<TextBlock Text="{Binding ActiveDescriptionDisplay}"
											 FontSize="14"
											 TextWrapping="Wrap" />
									</StackPanel>

									<!-- Stop Button -->
									<Button Grid.Row="3"
									   Content="{markup:Localize StopWork}"
									   Command="{Binding StopWorkCommand}"
									   Style="{StaticResource PrimaryButtonStyle}"
									   Background="{StaticResource ErrorBrush}"
									   BorderBrush="{StaticResource ErrorBrush}"
									   HorizontalAlignment="Stretch"
									   Height="48"
									   FontSize="16"
									   FontWeight="Bold">
										<Button.CommandParameter>
											<x:Null />
										</Button.CommandParameter>
									</Button>
								</Grid>
							</materialDesign:Card>

							<!-- Start Work Card -->
							<materialDesign:Card Style="{StaticResource CardStyle}">
								<StackPanel>
									<TextBlock Text="{markup:Localize StartWork}"
										 Style="{StaticResource SubheaderTextStyle}" />

									<!-- Work Input -->
									<TextBox Text="{Binding WorkInput, UpdateSourceTrigger=PropertyChanged}"
										Style="{StaticResource InputTextBoxStyle}"
										materialDesign:HintAssist.Hint="{markup:Localize WorkInputHint}"
										materialDesign:HintAssist.IsFloating="True"
										AcceptsReturn="False"
										MaxLength="200"
										Margin="0,0,0,16">
										<TextBox.InputBindings>
											<KeyBinding Key="Enter" Command="{Binding StartWorkCommand}" />
										</TextBox.InputBindings>
									</TextBox>

									<!-- Detected Info -->
									<StackPanel Margin="0,0,0,16"
										  Visibility="{Binding DetectedTicketId, Converter={StaticResource NullToVisibilityConverter}}">
										<TextBlock FontSize="12"
											 Foreground="{StaticResource SuccessBrush}">
										<Run Text="{markup:Localize Detected}" />
										<Run Text="{Binding DetectedTicketId, Mode=OneWay}" FontWeight="Bold" />
										<Run Text=" - " />
										<Run Text="{Binding DetectedDescription, Mode=OneWay}" />
										</TextBlock>
									</StackPanel>

									<!-- Start Button -->
									<Button Content="{markup:Localize StartWorkButton}"
									   Command="{Binding StartWorkCommand}"
									   Style="{StaticResource PrimaryButtonStyle}"
									   Background="{StaticResource SuccessBrush}"
									   BorderBrush="{StaticResource SuccessBrush}"
									   HorizontalAlignment="Stretch"
									   Height="48"
									   FontSize="16"
									   FontWeight="Bold" />
								</StackPanel>
							</materialDesign:Card>

							<!-- Total Day Duration -->
							<materialDesign:Card Style="{StaticResource CardStyle}">
								<Grid>
									<Grid.ColumnDefinitions>
										<ColumnDefinition Width="Auto" />
										<ColumnDefinition Width="*" />
									</Grid.ColumnDefinitions>

									<materialDesign:PackIcon Grid.Column="0"
													   Kind="ClockOutline"
													   Width="24"
													   Height="24"
													   VerticalAlignment="Center"
													   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
													   Margin="0,0,12,0" />

									<StackPanel Grid.Column="1">
										<TextBlock Text="{markup:Localize TotalTime}"
											 FontSize="12"
											 Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											 Margin="0,0,0,4" />
										<TextBlock Text="{Binding TotalDayDuration}"
											 FontSize="20"
											 FontWeight="Medium" />
									</StackPanel>
								</Grid>
							</materialDesign:Card>

							<!-- Quick Actions -->
							<materialDesign:Card Style="{StaticResource CardStyle}">
								<StackPanel>
									<TextBlock Text="{markup:Localize QuickActions}"
										 Style="{StaticResource SubheaderTextStyle}" />

									<Button Command="{Binding SubmitWorklogCommand}"
									   Style="{StaticResource SecondaryButtonStyle}"
									   Margin="0,0,0,8">
										<Button.Content>
											<StackPanel Orientation="Horizontal">
												<materialDesign:PackIcon Kind="Upload" VerticalAlignment="Center" Margin="0,0,8,0" />
												<TextBlock Text="{markup:Localize SubmitWorklogs}" VerticalAlignment="Center" />
											</StackPanel>
										</Button.Content>
									</Button>

									<Button Command="{Binding RefreshCommand}"
									   Style="{StaticResource SecondaryButtonStyle}">
										<Button.Content>
											<StackPanel Orientation="Horizontal">
												<materialDesign:PackIcon Kind="Refresh" VerticalAlignment="Center" Margin="0,0,8,0" />
												<TextBlock Text="{markup:Localize Refresh}" VerticalAlignment="Center" />
											</StackPanel>
										</Button.Content>
									</Button>
								</StackPanel>
							</materialDesign:Card>
						</StackPanel>

						<!-- Right Panel: Work Entries List -->
						<materialDesign:Card Grid.Column="2" Style="{StaticResource CardStyle}">
							<Grid>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="*" />
								</Grid.RowDefinitions>

								<!-- Header -->
								<TextBlock Grid.Row="0"
										   Text="{markup:Localize WorkEntries}"
										   Style="{StaticResource SubheaderTextStyle}"
										   Margin="0,0,0,16" />

								<!-- Date Picker with Navigation -->
								<DockPanel Grid.Row="1" Margin="0,0,0,16">
									<Button Command="{Binding AddWorkEntryCommand}"
										   Style="{StaticResource MaterialDesignIconButton}"
										   ToolTip="{markup:Localize AddNewWorkEntry}"
										   DockPanel.Dock="Right"
										   VerticalAlignment="Center">
										<materialDesign:PackIcon Kind="Plus" Width="24" Height="24" />
									</Button>

									<StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
										<Button Command="{Binding PreviousDayCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize PreviousDay}"
											   VerticalAlignment="Center"
											   Margin="0,0,8,0">
											<materialDesign:PackIcon Kind="ChevronLeft" Width="24" Height="24" />
										</Button>

										<DatePicker SelectedDate="{Binding SelectedDate}"
												   Style="{StaticResource InputDatePickerStyle}"
												   materialDesign:HintAssist.Hint="{markup:Localize SelectDate}"
												   Width="200"
												   VerticalAlignment="Center" />

										<Button Command="{Binding GoToTodayCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize GoToToday}"
											   VerticalAlignment="Center"
											   Margin="8,0,0,0">
											<materialDesign:PackIcon Kind="CalendarToday" Width="20" Height="20" />
										</Button>

										<Button Command="{Binding NextDayCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize NextDay}"
											   VerticalAlignment="Center"
											   Margin="0,0,0,0">
											<materialDesign:PackIcon Kind="ChevronRight" Width="24" Height="24" />
										</Button>
									</StackPanel>
								</DockPanel>

								<!-- DataGrid -->
								<DataGrid Grid.Row="2"
									 ItemsSource="{Binding WorkEntries}"
									 SelectedItem="{Binding SelectedWorkEntry}"
									 Style="{StaticResource WorkEntryDataGridStyle}">
									<DataGrid.Columns>
										<!-- Ticket -->
										<DataGridTextColumn Header="{markup:Localize Ticket}"
													   Binding="{Binding TicketId}"
													   Width="80">
											<DataGridTextColumn.ElementStyle>
												<Style TargetType="TextBlock">
													<Setter Property="FontWeight" Value="Medium" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding TicketId}" Value="{x:Null}">
															<Setter Property="Text" Value="--" />
															<Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground.Light}" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</DataGridTextColumn.ElementStyle>
										</DataGridTextColumn>

										<!-- Description -->
										<DataGridTextColumn Header="{markup:Localize Description}"
													   Binding="{Binding Description}"
													   Width="*"
													   MinWidth="200">
											<DataGridTextColumn.ElementStyle>
												<Style TargetType="TextBlock">
													<Setter Property="TextTrimming" Value="CharacterEllipsis" />
													<Style.Triggers>
														<DataTrigger Binding="{Binding Description}" Value="{x:Null}">
															<Setter Property="Text" Value="--" />
															<Setter Property="Foreground" Value="{DynamicResource MaterialDesign.Brush.Foreground.Light}" />
														</DataTrigger>
													</Style.Triggers>
												</Style>
											</DataGridTextColumn.ElementStyle>
										</DataGridTextColumn>

										<!-- Start Time -->
										<DataGridTextColumn Header="{markup:Localize Start}"
													   Binding="{Binding StartTime, Converter={StaticResource DateTimeToStringConverter}, ConverterParameter='HH:mm'}"
													   Width="80" />

										<!-- End Time -->
										<DataGridTextColumn Header="{markup:Localize End}"
													   Binding="{Binding EndTime, Converter={StaticResource DateTimeToStringConverter}, ConverterParameter='HH:mm'}"
													   Width="80" />

										<!-- Duration -->
										<DataGridTextColumn Header="{markup:Localize Duration}"
													   Binding="{Binding Duration, Converter={StaticResource TimeSpanToStringConverter}}"
													   Width="70">
											<DataGridTextColumn.ElementStyle>
												<Style TargetType="TextBlock">
													<Setter Property="FontWeight" Value="Medium" />
												</Style>
											</DataGridTextColumn.ElementStyle>
										</DataGridTextColumn>

										<!-- Status -->
										<DataGridTemplateColumn Header="{markup:Localize Status}" Width="80">
											<DataGridTemplateColumn.CellTemplate>
												<DataTemplate>
													<Border CornerRadius="12"
													   Padding="8,4"
													   HorizontalAlignment="Center">
														<Border.Style>
															<Style TargetType="Border">
																<Setter Property="Background" Value="{StaticResource CompletedWorkBrush}" />
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsActive}" Value="True">
																		<Setter Property="Background" Value="{StaticResource ActiveWorkBrush}" />
																	</DataTrigger>
																</Style.Triggers>
															</Style>
														</Border.Style>
														<TextBlock FontSize="11"
															 FontWeight="Bold"
															 Foreground="White">
															<TextBlock.Style>
																<Style TargetType="TextBlock">
																	<Setter Property="Text" Value="{markup:Localize Done}" />
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding IsActive}" Value="True">
																			<Setter Property="Text" Value="{markup:Localize Active}" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</TextBlock.Style>
														</TextBlock>
													</Border>
												</DataTemplate>
											</DataGridTemplateColumn.CellTemplate>
										</DataGridTemplateColumn>

										<!-- Actions -->
										<DataGridTemplateColumn Header="{markup:Localize Actions}" Width="125">
											<DataGridTemplateColumn.CellTemplate>
												<DataTemplate>
													<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
														<Button Style="{StaticResource IconButtonStyle}"
														   Command="{Binding DataContext.StartWorkFromHistoryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
														   CommandParameter="{Binding}"
														   ToolTip="{markup:Localize RestartWork}">
															<Button.Visibility>
																<Binding Path="IsActive" Converter="{StaticResource BoolToVisibilityConverter}" ConverterParameter="Inverse" />
															</Button.Visibility>
															<materialDesign:PackIcon Kind="Play" Width="16" Height="16" />
														</Button>
														<Button Style="{StaticResource IconButtonStyle}"
														   Command="{Binding DataContext.EditWorkEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
														   CommandParameter="{Binding}"
														   ToolTip="{markup:Localize Edit}">
															<materialDesign:PackIcon Kind="Pencil" Width="16" Height="16" />
														</Button>
														<Button Style="{StaticResource IconButtonStyle}"
														   Command="{Binding DataContext.DeleteWorkEntryCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
														   CommandParameter="{Binding}"
														   ToolTip="{markup:Localize Delete}">
															<materialDesign:PackIcon Kind="Delete" Width="16" Height="16" />
														</Button>
													</StackPanel>
												</DataTemplate>
											</DataGridTemplateColumn.CellTemplate>
										</DataGridTemplateColumn>
									</DataGrid.Columns>
								</DataGrid>
							</Grid>
						</materialDesign:Card>
					</Grid>
				</ScrollViewer>

				<!-- Snackbar for notifications -->
				<materialDesign:Snackbar x:Name="MainSnackbar"
									Grid.Row="1">
					<materialDesign:Snackbar.Style>
						<Style TargetType="materialDesign:Snackbar" BasedOn="{StaticResource {x:Type materialDesign:Snackbar}}">
							<Setter Property="Background" Value="Transparent" />
						</Style>
					</materialDesign:Snackbar.Style>
				</materialDesign:Snackbar>
			</Grid>
		</materialDesign:DialogHost>
	</Border>
</Window>