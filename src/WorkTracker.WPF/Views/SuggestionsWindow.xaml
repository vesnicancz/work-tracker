<Window x:Class="WorkTracker.WPF.Views.SuggestionsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		xmlns:vm="clr-namespace:WorkTracker.UI.Shared.ViewModels;assembly=WorkTracker.UI.Shared"
		d:DataContext="{d:DesignInstance Type=vm:SuggestionsViewModel}"
		mc:Ignorable="d"
		Title="{markup:Localize Suggestions}"
		Height="550"
		Width="500"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ResizeMode="NoResize"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40"
					 ResizeBorderThickness="0"
					 GlassFrameThickness="0"
					 CornerRadius="0"
					 UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
		<converters:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
	</Window.Resources>

	<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
			BorderThickness="1"
			CornerRadius="8"
			Margin="10"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="5" Direction="315" />
		</Border.Effect>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- Title bar -->
			<materialDesign:ColorZone Grid.Row="0"
									  Padding="16,8"
									  CornerRadius="8,8,0,0"
									  materialDesign:ElevationAssist.Elevation="Dp2"
									  Background="{StaticResource TitleBarGradientBrush}">
				<DockPanel>
					<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
						<Button Style="{StaticResource MaterialDesignFlatButton}"
								Command="{Binding RefreshCommand}"
								Width="36" Height="32" Padding="0"
								Foreground="White"
								ToolTip="{markup:Localize Refresh}"
								WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
						</Button>
						<Button x:Name="CloseButton"
								Style="{StaticResource MaterialDesignFlatButton}"
								Width="36" Height="32" Padding="0"
								Foreground="White"
								ToolTip="{markup:Localize Close}"
								WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
						</Button>
					</StackPanel>

					<StackPanel Orientation="Horizontal">
						<materialDesign:PackIcon Kind="LightbulbOutline"
												Width="24" Height="24"
												VerticalAlignment="Center"
												Margin="0,0,8,0"
												Foreground="White" />
						<TextBlock Text="{markup:Localize Suggestions}"
								  FontSize="18" FontWeight="SemiBold"
								  VerticalAlignment="Center"
								  Foreground="White" />
					</StackPanel>
				</DockPanel>
			</materialDesign:ColorZone>

			<!-- Content -->
			<Grid Grid.Row="1">
				<!-- Loading -->
				<ProgressBar IsIndeterminate="True"
							 VerticalAlignment="Top"
							 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

				<!-- Groups -->
				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
					<ItemsControl ItemsSource="{Binding Groups}" Margin="16">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<materialDesign:Card Style="{StaticResource CardStyle}" Margin="0,0,0,6">
									<StackPanel>
										<!-- Clickable accordion header -->
										<Button Command="{Binding DataContext.ToggleGroupCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
												CommandParameter="{Binding}"
												Style="{StaticResource MaterialDesignFlatButton}"
												HorizontalContentAlignment="Stretch"
												Padding="0" Margin="0" Height="Auto">
											<StackPanel Orientation="Horizontal">
												<materialDesign:PackIcon Width="16" Height="16"
																	VerticalAlignment="Center"
																	Margin="0,0,6,0"
																	Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}">
													<materialDesign:PackIcon.Style>
														<Style TargetType="materialDesign:PackIcon">
															<Setter Property="Kind" Value="ChevronRight" />
															<Style.Triggers>
																<DataTrigger Binding="{Binding IsExpanded}" Value="True">
																	<Setter Property="Kind" Value="ChevronDown" />
																</DataTrigger>
															</Style.Triggers>
														</Style>
													</materialDesign:PackIcon.Style>
												</materialDesign:PackIcon>
												<materialDesign:PackIcon Kind="{Binding IconHint, FallbackValue=LightbulbOutline, TargetNullValue=LightbulbOutline}"
																	Width="20" Height="20"
																	Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
																	VerticalAlignment="Center"
																	Margin="0,0,8,0" />
												<TextBlock FontSize="14" FontWeight="Medium"
														   VerticalAlignment="Center">
													<Run Text="{Binding Name, Mode=OneWay}" />
												</TextBlock>
												<Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
														CornerRadius="8" Padding="6,2"
														VerticalAlignment="Center" Margin="8,0,0,0">
													<TextBlock Text="{Binding Count, Mode=OneWay}"
															   FontSize="11" FontWeight="SemiBold"
															   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" />
												</Border>
											</StackPanel>
										</Button>

										<!-- Expandable content -->
									<StackPanel Margin="0,8,0,0"
												Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVisibilityConverter}}">

										<!-- Error -->
										<Border Background="#20FF4444" CornerRadius="4" Padding="8,6"
												Margin="0,0,0,8"
												Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}">
											<TextBlock Text="{Binding Error}"
													   Foreground="{StaticResource ErrorBrush}"
													   FontSize="12" TextWrapping="Wrap" />
										</Border>

										<!-- Search box with icon -->
										<DockPanel Margin="0,0,0,8"
												   Visibility="{Binding SupportsSearch, Converter={StaticResource BoolToVisibilityConverter}}">
											<materialDesign:PackIcon Kind="Magnify" DockPanel.Dock="Left"
																Width="18" Height="18"
																Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
																VerticalAlignment="Center"
																Margin="0,0,8,0" />
											<TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
													 materialDesign:HintAssist.Hint="{markup:Localize SearchSuggestions}"
													 materialDesign:HintAssist.IsFloating="False" />
										</DockPanel>

										<!-- Empty state -->
										<TextBlock Text="{markup:Localize NoSuggestions}"
												   FontSize="12" Opacity="0.5"
												   HorizontalAlignment="Center" Margin="0,8"
												   Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibilityConverter}}" />

										<!-- Items -->
										<ItemsControl ItemsSource="{Binding Items}">
											<ItemsControl.ItemTemplate>
												<DataTemplate>
													<Button Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
															CommandParameter="{Binding}"
															HorizontalContentAlignment="Stretch"
															Padding="8,6" Margin="0,1" Height="Auto">
														<Button.Style>
															<Style TargetType="Button" BasedOn="{StaticResource MaterialDesignFlatButton}">
																<Style.Triggers>
																	<DataTrigger Binding="{Binding IsPast}" Value="True">
																		<Setter Property="Opacity" Value="0.45" />
																	</DataTrigger>
																	<MultiDataTrigger>
																		<MultiDataTrigger.Conditions>
																			<Condition Binding="{Binding IsPast}" Value="True" />
																			<Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
																		</MultiDataTrigger.Conditions>
																		<Setter Property="Opacity" Value="1.0" />
																	</MultiDataTrigger>
																</Style.Triggers>
															</Style>
														</Button.Style>
														<Grid>
															<Grid.ColumnDefinitions>
																<ColumnDefinition Width="Auto" />
																<ColumnDefinition Width="*" />
															</Grid.ColumnDefinitions>
															<!-- Time badge (calendar events) -->
															<TextBlock Grid.Column="0"
																	   Text="{Binding BadgeText}"
																	   FontSize="12"
																	   FontFamily="Consolas"
																	   Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
																	   VerticalAlignment="Center"
																	   Margin="0,0,10,0"
																	   Visibility="{Binding HasTimeSlot, Converter={StaticResource BoolToVisibilityConverter}}" />
															<!-- Ticket ID badge (Jira issues) -->
															<TextBlock Grid.Column="0"
																	   Text="{Binding BadgeText}"
																	   FontSize="12"
																	   FontWeight="SemiBold"
																	   Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
																	   VerticalAlignment="Center"
																	   Margin="0,0,10,0"
																	   Visibility="{Binding IsBadgeAccent, Converter={StaticResource BoolToVisibilityConverter}}" />
															<!-- Title -->
															<TextBlock Grid.Column="1"
																	   Text="{Binding Title}"
																	   TextTrimming="CharacterEllipsis"
																	   VerticalAlignment="Center" />
														</Grid>
													</Button>
												</DataTemplate>
											</ItemsControl.ItemTemplate>
										</ItemsControl>
									</StackPanel>
								</StackPanel>
								</materialDesign:Card>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</Grid>
	</Border>
</Window>
