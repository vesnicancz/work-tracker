<Window x:Class="WorkTracker.WPF.Views.SuggestionsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		xmlns:vm="clr-namespace:WorkTracker.UI.Shared.ViewModels;assembly=WorkTracker.UI.Shared"
		d:DataContext="{d:DesignInstance Type=vm:SuggestionsViewModel}"
		mc:Ignorable="d"
		Title="{markup:Localize Suggestions}"
		Height="550"
		Width="500"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ResizeMode="NoResize"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40"
					 ResizeBorderThickness="0"
					 GlassFrameThickness="0"
					 CornerRadius="0"
					 UseAeroCaptionButtons="False" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
	</Window.Resources>

	<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
			BorderThickness="1"
			CornerRadius="8"
			Margin="10"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="15" ShadowDepth="5" Direction="315" />
		</Border.Effect>

		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
			</Grid.RowDefinitions>

			<!-- Title bar -->
			<materialDesign:ColorZone Grid.Row="0"
									  Padding="16,8"
									  CornerRadius="8,8,0,0"
									  materialDesign:ElevationAssist.Elevation="Dp2"
									  Background="{StaticResource TitleBarGradientBrush}">
				<DockPanel>
					<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
						<Button Style="{StaticResource MaterialDesignFlatButton}"
								Command="{Binding RefreshCommand}"
								Width="36" Height="32" Padding="0"
								Foreground="White"
								ToolTip="{markup:Localize Refresh}"
								WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Refresh" Width="18" Height="18" />
						</Button>
						<Button x:Name="CloseButton"
								Style="{StaticResource MaterialDesignFlatButton}"
								Width="36" Height="32" Padding="0"
								Foreground="White"
								ToolTip="{markup:Localize Close}"
								WindowChrome.IsHitTestVisibleInChrome="True">
							<materialDesign:PackIcon Kind="Close" Width="18" Height="18" />
						</Button>
					</StackPanel>

					<StackPanel Orientation="Horizontal">
						<materialDesign:PackIcon Kind="LightbulbOutline"
												Width="24" Height="24"
												VerticalAlignment="Center"
												Margin="0,0,8,0"
												Foreground="White" />
						<TextBlock Text="{markup:Localize Suggestions}"
								  FontSize="18" FontWeight="SemiBold"
								  VerticalAlignment="Center"
								  Foreground="White" />
					</StackPanel>
				</DockPanel>
			</materialDesign:ColorZone>

			<!-- Content -->
			<Grid Grid.Row="1">
				<!-- Loading -->
				<ProgressBar IsIndeterminate="True"
							 VerticalAlignment="Top"
							 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

				<!-- Groups -->
				<ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
					<ItemsControl ItemsSource="{Binding Groups}">
						<ItemsControl.ItemTemplate>
							<DataTemplate>
								<StackPanel Margin="0,0,0,16">
									<!-- Group header -->
									<TextBlock FontSize="14" FontWeight="Medium" Margin="0,0,0,8">
										<Run Text="{Binding Name, Mode=OneWay}" />
										<Run Text=" (" /><Run Text="{Binding Count, Mode=OneWay}" /><Run Text=")" />
									</TextBlock>

									<!-- Search box -->
									<TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
											 materialDesign:HintAssist.Hint="{markup:Localize SearchSuggestions}"
											 materialDesign:HintAssist.IsFloating="False"
											 Margin="0,0,0,8"
											 Visibility="{Binding SupportsSearch, Converter={StaticResource BoolToVisibilityConverter}}" />

									<!-- Error -->
									<TextBlock Text="{Binding Error}"
											   Foreground="{StaticResource ErrorBrush}"
											   FontSize="12" TextWrapping="Wrap"
											   Margin="0,0,0,8"
											   Visibility="{Binding HasError, Converter={StaticResource BoolToVisibilityConverter}}" />

									<!-- Items -->
									<ItemsControl ItemsSource="{Binding Items}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<Button Command="{Binding DataContext.SelectCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
														CommandParameter="{Binding}"
														Style="{StaticResource MaterialDesignFlatButton}"
														HorizontalContentAlignment="Stretch"
														Padding="8,6" Margin="0,1" Height="Auto">
													<Grid>
														<Grid.RowDefinitions>
															<RowDefinition Height="Auto" />
															<RowDefinition Height="Auto" />
														</Grid.RowDefinitions>
														<DockPanel Grid.Row="0">
															<TextBlock DockPanel.Dock="Right"
																	   Text="{Binding Source}"
																	   FontSize="10" Opacity="0.5"
																	   VerticalAlignment="Center"
																	   Margin="8,0,0,0" />
															<TextBlock Text="{Binding DisplayText}"
																	   FontWeight="Medium"
																	   TextTrimming="CharacterEllipsis" />
														</DockPanel>
														<TextBlock Grid.Row="1"
																   Text="{Binding TimeDisplay}"
																   FontSize="11" Opacity="0.6"
																   Visibility="{Binding HasTimeSlot, Converter={StaticResource BoolToVisibilityConverter}}" />
													</Grid>
												</Button>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>
								</StackPanel>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>
				</ScrollViewer>
			</Grid>
		</Grid>
	</Border>
</Window>
