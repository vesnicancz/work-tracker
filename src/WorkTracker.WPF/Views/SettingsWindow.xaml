<Window x:Class="WorkTracker.WPF.Views.SettingsWindow"
		xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
		xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:viewmodels="clr-namespace:WorkTracker.WPF.ViewModels"
		xmlns:markup="clr-namespace:WorkTracker.WPF.Markup"
		xmlns:converters="clr-namespace:WorkTracker.WPF.Converters"
		d:DataContext="{d:DesignInstance Type=viewmodels:SettingsViewModel}"
		mc:Ignorable="d"
		Title="{markup:Localize Settings}"
		Height="700"
		Width="700"
		WindowStartupLocation="CenterOwner"
		WindowStyle="None"
		ResizeMode="NoResize"
		AllowsTransparency="True"
		Background="Transparent"
		FontFamily="{materialDesign:MaterialDesignFont}"
		TextElement.Foreground="{DynamicResource MaterialDesign.Brush.Foreground}"
		TextElement.FontWeight="Regular"
		TextElement.FontSize="13">

	<WindowChrome.WindowChrome>
		<WindowChrome CaptionHeight="40"
					  GlassFrameThickness="0"
					  CornerRadius="0"
					  ResizeBorderThickness="0" />
	</WindowChrome.WindowChrome>

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
		<converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
	</Window.Resources>

	<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
			BorderThickness="1"
			CornerRadius="8"
			Margin="15"
			Background="{DynamicResource MaterialDesign.Brush.Background}">
		<Border.Effect>
			<DropShadowEffect Color="Black"
							  Opacity="0.3"
							  BlurRadius="20"
							  ShadowDepth="8"
							  Direction="315" />
		</Border.Effect>
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="Auto" />
				<RowDefinition Height="*" />
				<RowDefinition Height="Auto" />
			</Grid.RowDefinitions>

			<!-- Title Bar -->
			<materialDesign:ColorZone Grid.Row="0"
									 Padding="16,8"
									 CornerRadius="8,8,0,0"
									 materialDesign:ElevationAssist.Elevation="Dp4"
									 Background="{StaticResource TitleBarGradientBrush}">
				<DockPanel>
					<!-- Close Button -->
					<Button x:Name="CloseButton"
						   DockPanel.Dock="Right"
						   Style="{StaticResource MaterialDesignFlatButton}"
						   Width="40"
						   Height="32"
						   Padding="0"
						   Foreground="White"
						   ToolTip="{markup:Localize Close}"
						   WindowChrome.IsHitTestVisibleInChrome="True">
						<materialDesign:PackIcon Kind="Close"
												Width="20"
												Height="20" />
					</Button>

					<!-- Title -->
					<TextBlock Text="{markup:Localize Settings}"
							  FontSize="16"
							  FontWeight="Medium"
							  VerticalAlignment="Center"
							  Foreground="White" />
				</DockPanel>
			</materialDesign:ColorZone>

			<!-- Content with Tabs -->
			<TabControl Grid.Row="1"
					   Style="{StaticResource MaterialDesignNavigationRailTabControl}"
					   Margin="0,16,0,16">

				<!-- General Tab -->
				<TabItem Header="{markup:Localize General}">
					<ScrollViewer VerticalScrollBarVisibility="Auto"
								 Padding="24,16,24,0">
						<StackPanel Margin="8,0,8,0">
							<!-- Window Behavior Section -->
							<TextBlock Text="{markup:Localize WindowBehavior}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,16" />

							<TextBlock Text="{markup:Localize WhenClosingMainWindow}"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
									  Margin="0,0,0,12" />

							<RadioButton IsChecked="{Binding IsMinimizeToTray}"
										Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="{markup:Localize MinimizeToTray}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize MinimizeToTrayDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</RadioButton>

							<RadioButton IsChecked="{Binding IsExitApplication}">
								<StackPanel>
									<TextBlock Text="{markup:Localize ExitApplication}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize ExitApplicationDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</RadioButton>

							<!-- Startup Section -->
							<Separator Margin="0,24,0,24" />

							<TextBlock Text="{markup:Localize Startup}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,16" />

							<CheckBox IsChecked="{Binding StartWithWindows}">
								<StackPanel>
									<TextBlock Text="{markup:Localize StartWithWindows}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize StartWithWindowsDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</CheckBox>

							<CheckBox IsChecked="{Binding StartMinimized}"
									 Margin="0,12,0,0">
								<StackPanel>
									<TextBlock Text="{markup:Localize StartMinimized}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize StartMinimizedDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</CheckBox>

							<!-- Updates -->
							<Separator Margin="0,24,0,24" />

							<TextBlock Text="{markup:Localize Updates}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,16" />

							<CheckBox IsChecked="{Binding CheckForUpdates}">
								<StackPanel>
									<TextBlock Text="{markup:Localize CheckForUpdates}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize CheckForUpdatesDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</CheckBox>
						</StackPanel>
					</ScrollViewer>
				</TabItem>

				<!-- Favorites Tab -->
				<TabItem Header="{markup:Localize Favorites}">
					<Grid Margin="24,16,24,0">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto" />
							<RowDefinition Height="*" />
							<RowDefinition Height="Auto" />
						</Grid.RowDefinitions>

						<!-- Section Header -->
						<StackPanel Grid.Row="0" Margin="8,0,8,16">
							<TextBlock Text="{markup:Localize Favorites}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,8" />
							<TextBlock Text="{markup:Localize FavoritesDescription}"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
									  TextWrapping="Wrap" />
						</StackPanel>

						<!-- Main Content -->
						<Grid Grid.Row="1" Margin="8,0,8,0">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="*" />
								<ColumnDefinition Width="16" />
								<ColumnDefinition Width="*" />
							</Grid.ColumnDefinitions>

							<!-- Left: List of favorites -->
							<Border Grid.Column="0"
								   BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
								   BorderThickness="1"
								   CornerRadius="4"
								   Background="{DynamicResource MaterialDesign.Brush.Background.Light}">
								<Grid>
									<Grid.RowDefinitions>
										<RowDefinition Height="*" />
										<RowDefinition Height="Auto" />
									</Grid.RowDefinitions>

									<ListBox Grid.Row="0"
											ItemsSource="{Binding FavoriteWorkItems}"
											SelectedItem="{Binding SelectedFavorite}"
											Style="{StaticResource MaterialDesignListBox}"
											Margin="0">
										<ListBox.ItemTemplate>
											<DataTemplate>
												<StackPanel Margin="8,4">
													<StackPanel Orientation="Horizontal">
														<materialDesign:PackIcon Width="14" Height="14"
																				VerticalAlignment="Center"
																				Margin="0,0,6,0">
															<materialDesign:PackIcon.Style>
																<Style TargetType="materialDesign:PackIcon">
																	<Setter Property="Kind" Value="Star" />
																	<Setter Property="Foreground" Value="Gold" />
																	<Style.Triggers>
																		<DataTrigger Binding="{Binding ShowAsTemplate}" Value="True">
																			<Setter Property="Kind" Value="SquareEditOutline" />
																			<Setter Property="Foreground" Value="DodgerBlue" />
																		</DataTrigger>
																	</Style.Triggers>
																</Style>
															</materialDesign:PackIcon.Style>
														</materialDesign:PackIcon>
														<TextBlock Text="{Binding Name}"
																  FontWeight="Medium"
																  VerticalAlignment="Center" />
													</StackPanel>
													<TextBlock Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
															  FontSize="11"
															  Margin="20,0,0,0">
														<TextBlock.Text>
															<MultiBinding StringFormat="{}{0} - {1}">
																<Binding Path="TicketId" TargetNullValue="(no ticket)" />
																<Binding Path="Description" TargetNullValue="(no description)" />
															</MultiBinding>
														</TextBlock.Text>
													</TextBlock>
												</StackPanel>
											</DataTemplate>
										</ListBox.ItemTemplate>
									</ListBox>

									<!-- List toolbar: Remove + Move Up/Down -->
									<StackPanel Grid.Row="1"
											   Orientation="Horizontal"
											   HorizontalAlignment="Right"
											   Margin="8">
										<Button Command="{Binding RemoveFavoriteCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize RemoveFavorite}"
											   Foreground="Crimson"
											   Width="32"
											   Height="32"
											   Margin="0,0,8,0">
											<materialDesign:PackIcon Kind="Delete" />
										</Button>
										<Button Command="{Binding MoveFavoriteUpCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize MoveUp}"
											   Width="32"
											   Height="32">
											<materialDesign:PackIcon Kind="ArrowUp" />
										</Button>
										<Button Command="{Binding MoveFavoriteDownCommand}"
											   Style="{StaticResource MaterialDesignIconButton}"
											   ToolTip="{markup:Localize MoveDown}"
											   Width="32"
											   Height="32">
											<materialDesign:PackIcon Kind="ArrowDown" />
										</Button>
									</StackPanel>
								</Grid>
							</Border>

							<!-- Right: Placeholder when no favorite selected -->
							<TextBlock Grid.Column="2"
									  Text="{markup:Localize SelectFavoriteToEdit}"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
									  HorizontalAlignment="Center"
									  VerticalAlignment="Center"
									  TextWrapping="Wrap"
									  TextAlignment="Center"
									  Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />

							<!-- Right: Edit form -->
							<Border Grid.Column="2"
								   BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
								   BorderThickness="1"
								   CornerRadius="4"
								   Padding="16"
								   Background="{DynamicResource MaterialDesign.Brush.Background.Light}"
								   Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibilityConverter}}">
								<StackPanel>
									<!-- Form header indicating mode -->
									<TextBlock FontSize="14"
											  FontWeight="Medium"
											  Margin="0,0,0,16">
										<TextBlock.Style>
											<Style TargetType="TextBlock">
												<Setter Property="Text" Value="{markup:Localize EditFavorite}" />
												<Style.Triggers>
													<DataTrigger Binding="{Binding IsAddingFavorite}" Value="True">
														<Setter Property="Text" Value="{markup:Localize NewFavorite}" />
													</DataTrigger>
												</Style.Triggers>
											</Style>
										</TextBlock.Style>
									</TextBlock>

									<TextBox Text="{Binding EditingFavoriteName, UpdateSourceTrigger=PropertyChanged}"
											materialDesign:HintAssist.Hint="{markup:Localize FavoriteName}"
											Style="{StaticResource MaterialDesignOutlinedTextBox}"
											Margin="0,0,0,16" />

									<TextBox Text="{Binding EditingFavoriteTicket, UpdateSourceTrigger=PropertyChanged}"
											materialDesign:HintAssist.Hint="{markup:Localize FavoriteTicket}"
											Style="{StaticResource MaterialDesignOutlinedTextBox}"
											Margin="0,0,0,16" />

									<TextBox Text="{Binding EditingFavoriteDescription, UpdateSourceTrigger=PropertyChanged}"
											materialDesign:HintAssist.Hint="{markup:Localize FavoriteDescription}"
											Style="{StaticResource MaterialDesignOutlinedTextBox}"
											TextWrapping="Wrap"
											AcceptsReturn="True"
											MinHeight="60"
											Margin="0,0,0,16" />

									<CheckBox IsChecked="{Binding EditingFavoriteShowAsTemplate}"
											 Margin="0,0,0,16">
										<StackPanel>
											<TextBlock Text="{markup:Localize FavoriteShowAsTemplate}"
													  FontWeight="Medium" />
											<TextBlock Text="{markup:Localize FavoriteShowAsTemplateDesc}"
													  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
													  FontSize="11"
													  TextWrapping="Wrap"
													  Margin="0,4,0,0" />
										</StackPanel>
									</CheckBox>

									<StackPanel Orientation="Horizontal"
											   HorizontalAlignment="Right">
										<Button Content="{markup:Localize Cancel}"
											   Command="{Binding CancelEditFavoriteCommand}"
											   Style="{StaticResource MaterialDesignOutlinedButton}"
											   Margin="0,0,8,0" />
										<Button Content="{markup:Localize Save}"
											   Command="{Binding SaveFavoriteCommand}"
											   Style="{StaticResource MaterialDesignRaisedButton}" />
									</StackPanel>
								</StackPanel>
							</Border>
						</Grid>

						<!-- Add button -->
						<Button Grid.Row="2"
							   Command="{Binding AddFavoriteCommand}"
							   Style="{StaticResource MaterialDesignOutlinedButton}"
							   HorizontalAlignment="Left"
							   Margin="8,16,8,8">
							<StackPanel Orientation="Horizontal">
								<materialDesign:PackIcon Kind="Plus"
													   VerticalAlignment="Center"
													   Margin="0,0,8,0" />
								<TextBlock Text="{markup:Localize AddFavorite}"
										  VerticalAlignment="Center" />
							</StackPanel>
						</Button>
					</Grid>
				</TabItem>

				<!-- Pomodoro Tab -->
				<TabItem Header="{markup:Localize Pomodoro}">
					<ScrollViewer VerticalScrollBarVisibility="Auto"
								 Padding="24,16,24,0">
						<StackPanel Margin="8,0,8,0">
							<TextBlock Text="{markup:Localize Pomodoro}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,16" />

							<CheckBox IsChecked="{Binding PomodoroEnabled}"
									 Margin="0,0,0,12">
								<StackPanel>
									<TextBlock Text="{markup:Localize PomodoroEnabled}"
											  FontWeight="Medium" />
									<TextBlock Text="{markup:Localize PomodoroEnabledDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
								</StackPanel>
							</CheckBox>

							<Separator Margin="0,8,0,24" />

							<StackPanel IsEnabled="{Binding PomodoroEnabled}">
								<!-- Duration settings -->
								<TextBox Text="{Binding PomodoroWorkMinutes, UpdateSourceTrigger=PropertyChanged}"
									materialDesign:HintAssist.Hint="{markup:Localize PomodoroWorkMinutes}"
									materialDesign:HintAssist.IsFloating="True"
									Style="{StaticResource MaterialDesignOutlinedTextBox}"
									Margin="0,0,0,16" />

								<TextBox Text="{Binding PomodoroShortBreakMinutes, UpdateSourceTrigger=PropertyChanged}"
									materialDesign:HintAssist.Hint="{markup:Localize PomodoroShortBreakMinutes}"
									materialDesign:HintAssist.IsFloating="True"
									Style="{StaticResource MaterialDesignOutlinedTextBox}"
									Margin="0,0,0,16" />

								<TextBox Text="{Binding PomodoroLongBreakMinutes, UpdateSourceTrigger=PropertyChanged}"
									materialDesign:HintAssist.Hint="{markup:Localize PomodoroLongBreakMinutes}"
									materialDesign:HintAssist.IsFloating="True"
									Style="{StaticResource MaterialDesignOutlinedTextBox}"
									Margin="0,0,0,16" />

								<TextBox Text="{Binding PomodorosBeforeLongBreak, UpdateSourceTrigger=PropertyChanged}"
									materialDesign:HintAssist.Hint="{markup:Localize PomodorosBeforeLongBreak}"
									materialDesign:HintAssist.IsFloating="True"
									Style="{StaticResource MaterialDesignOutlinedTextBox}"
									Margin="0,0,0,16" />

								<Separator Margin="0,8,0,24" />

								<!-- Integration toggles -->
								<CheckBox IsChecked="{Binding PomodoroAutoStartTracking}"
									 Margin="0,0,0,12">
									<StackPanel>
										<TextBlock Text="{markup:Localize PomodoroAutoStartTracking}"
											  FontWeight="Medium" />
										<TextBlock Text="{markup:Localize PomodoroAutoStartTrackingDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
									</StackPanel>
								</CheckBox>

								<CheckBox IsChecked="{Binding PomodoroAutoStopTracking}"
									 Margin="0,0,0,12">
									<StackPanel>
										<TextBlock Text="{markup:Localize PomodoroAutoStopTracking}"
											  FontWeight="Medium" />
										<TextBlock Text="{markup:Localize PomodoroAutoStopTrackingDesc}"
											  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
											  FontSize="11"
											  TextWrapping="Wrap"
											  Margin="0,4,0,0" />
									</StackPanel>
								</CheckBox>

							</StackPanel>
						</StackPanel>
					</ScrollViewer>
				</TabItem>

				<!-- Plugins Tab -->
				<TabItem Header="{markup:Localize Plugins}">
					<Grid>
						<!-- No plugins message -->
						<TextBlock Text="{markup:Localize NoPluginsAvailable}"
								  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
								  HorizontalAlignment="Center"
								  VerticalAlignment="Center"
								  FontSize="14"
								  Visibility="{Binding HasPlugins, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Inverse}" />

						<!-- Plugin settings -->
						<ScrollViewer VerticalScrollBarVisibility="Auto"
								 Padding="24,16,24,0"
								 Visibility="{Binding HasPlugins, Converter={StaticResource BoolToVisibilityConverter}}">
						<StackPanel Margin="8,0,8,0">
							<!-- Plugins Section -->
							<TextBlock Text="{markup:Localize Plugins}"
									  FontSize="16"
									  FontWeight="Medium"
									  Margin="0,0,0,16" />

							<TextBlock Text="{markup:Localize SelectPlugin}"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
									  Margin="0,0,0,12" />

							<!-- Plugin Selection -->
							<ComboBox ItemsSource="{Binding Plugins}"
									 SelectedItem="{Binding SelectedPlugin}"
									 DisplayMemberPath="Name"
									 Margin="0,0,0,16"
									 materialDesign:HintAssist.Hint="{markup:Localize SelectPlugin}"
									 Style="{StaticResource MaterialDesignOutlinedComboBox}" />

							<!-- Plugin Details -->
							<Border BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
								   BorderThickness="1"
								   CornerRadius="4"
								   Padding="16"
								   Margin="0,0,0,16"
								   Background="{DynamicResource MaterialDesign.Brush.Background.Light}">
								<StackPanel>
									<!-- Enable/Disable Plugin Toggle -->
									<CheckBox IsChecked="{Binding SelectedPlugin.IsEnabled}"
											 Margin="0,0,0,16">
										<StackPanel>
											<TextBlock Text="{markup:Localize EnablePlugin}"
													  FontWeight="Medium" />
											<TextBlock Text="{markup:Localize EnablePluginDesc}"
													  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
													  FontSize="11"
													  TextWrapping="Wrap"
													  Margin="0,4,0,0" />
										</StackPanel>
									</CheckBox>

									<Separator Margin="0,0,0,16" />

									<Grid>
										<Grid.ColumnDefinitions>
											<ColumnDefinition Width="Auto" />
											<ColumnDefinition Width="*" />
										</Grid.ColumnDefinitions>
										<Grid.RowDefinitions>
											<RowDefinition Height="Auto" />
											<RowDefinition Height="Auto" />
											<RowDefinition Height="Auto" />
											<RowDefinition Height="Auto" />
										</Grid.RowDefinitions>

										<TextBlock Grid.Row="0" Grid.Column="0"
												  Text="{markup:Localize PluginName}"
												  FontWeight="Medium"
												  Margin="0,0,12,8" />
										<TextBlock Grid.Row="0" Grid.Column="1"
												  Text="{Binding SelectedPlugin.Name}"
												  Margin="0,0,0,8" />

										<TextBlock Grid.Row="1" Grid.Column="0"
												  Text="{markup:Localize PluginVersion}"
												  FontWeight="Medium"
												  Margin="0,0,12,8" />
										<TextBlock Grid.Row="1" Grid.Column="1"
												  Text="{Binding SelectedPlugin.Version}"
												  Margin="0,0,0,8" />

										<TextBlock Grid.Row="2" Grid.Column="0"
												  Text="{markup:Localize PluginAuthor}"
												  FontWeight="Medium"
												  Margin="0,0,12,8" />
										<TextBlock Grid.Row="2" Grid.Column="1"
												  Text="{Binding SelectedPlugin.Author}"
												  Margin="0,0,0,8" />

										<TextBlock Grid.Row="3" Grid.Column="0"
												  Text="{markup:Localize PluginDescription}"
												  FontWeight="Medium"
												  VerticalAlignment="Top"
												  Margin="0,0,12,0" />
										<TextBlock Grid.Row="3" Grid.Column="1"
												  Text="{Binding SelectedPlugin.Description}"
												  TextWrapping="Wrap" />
									</Grid>

									<!-- Configuration Fields -->
									<TextBlock Text="{markup:Localize Configuration}"
											  FontWeight="Medium"
											  FontSize="14"
											  Margin="0,16,0,12" />

									<ItemsControl ItemsSource="{Binding SelectedPlugin.ConfigurationFields}">
										<ItemsControl.ItemTemplate>
											<DataTemplate>
												<StackPanel Margin="0,0,0,12">
													<StackPanel Visibility="{Binding IsTextInput, Converter={StaticResource BooleanToVisibilityConverter}}">
														<TextBlock Text="{Binding Label}"
																  FontWeight="Medium"
																  Margin="0,0,0,4" />
														<TextBlock Text="{Binding Description}"
																  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
																  FontSize="11"
																  TextWrapping="Wrap"
																  Margin="0,0,0,4" />
														<TextBox Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
																materialDesign:HintAssist.Hint="{Binding Placeholder}"
																Style="{StaticResource MaterialDesignOutlinedTextBox}" />
													</StackPanel>
													<StackPanel Visibility="{Binding IsCheckbox, Converter={StaticResource BooleanToVisibilityConverter}}">
														<CheckBox IsChecked="{Binding BoolValue, Mode=TwoWay}"
																 Content="{Binding Label}"
																 FontWeight="Medium" />
														<TextBlock Text="{Binding Description}"
																  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
																  FontSize="11"
																  TextWrapping="Wrap"
																  Margin="24,2,0,0" />
													</StackPanel>
												</StackPanel>
											</DataTemplate>
										</ItemsControl.ItemTemplate>
									</ItemsControl>

									<!-- Test Connection Button -->
									<Button Command="{Binding TestConnectionCommand}"
										   Style="{StaticResource MaterialDesignOutlinedButton}"
										   Margin="0,8,0,0"
										   HorizontalAlignment="Left"
										   Visibility="{Binding SelectedPlugin.SupportsTestConnection, Converter={StaticResource BooleanToVisibilityConverter}}">
										<Button.Content>
											<StackPanel Orientation="Horizontal">
												<ProgressBar Style="{StaticResource MaterialDesignCircularProgressBar}"
														    Width="16"
														    Height="16"
														    Margin="0,0,8,0"
														    IsIndeterminate="True"
														    Visibility="{Binding IsTestingConnection, Converter={StaticResource BooleanToVisibilityConverter}}" />
												<TextBlock Text="{markup:Localize TestConnection}"
														  VerticalAlignment="Center" />
											</StackPanel>
										</Button.Content>
									</Button>

									<!-- Test Result -->
									<TextBlock Text="{Binding TestConnectionResult}"
											  Margin="0,8,0,0"
											  FontWeight="Medium" />
								</StackPanel>
							</Border>
						</StackPanel>
					</ScrollViewer>
					</Grid>
				</TabItem>
				<!-- About Tab -->
				<TabItem Header="{markup:Localize About}">
					<ScrollViewer VerticalScrollBarVisibility="Auto"
								 Padding="24,16,24,0">
						<StackPanel Margin="8,0,8,0">

							<TextBlock Text="{markup:Localize WorkTracker}"
									  FontSize="18"
									  FontWeight="Medium"
									  Margin="0,0,0,4" />
							<TextBlock Text="{Binding AppVersion, StringFormat='Version {0}'}"
									  FontSize="13"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" />

							<Separator Margin="0,14" />

							<!-- Keyboard Shortcuts -->
							<TextBlock Text="{markup:Localize KeyboardShortcuts}"
									  FontSize="14"
									  FontWeight="Medium"
									  Margin="0,0,0,10" />

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="130" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + Shift + W"
										  FontSize="12" FontFamily="Consolas"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="0" Grid.Column="1" Text="{markup:Localize AboutGlobalHotkeyDesc}"
										  FontSize="12" Margin="0,0,0,6" />

								<TextBlock Grid.Row="1" Grid.Column="0" Text="Enter"
										  FontSize="12" FontFamily="Consolas"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="1" Grid.Column="1" Text="{markup:Localize AboutEnterKeyDesc}"
										  FontSize="12" Margin="0,0,0,6" />
							</Grid>

							<Separator Margin="0,14" />

							<!-- Quick Reference -->
							<TextBlock Text="{markup:Localize QuickReference}"
									  FontSize="14"
									  FontWeight="Medium"
									  Margin="0,0,0,10" />

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="130" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:Localize AboutStartTracking}"
										  FontSize="12"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="0" Grid.Column="1" Text="{markup:Localize AboutStartTrackingDesc}"
										  FontSize="12" Margin="0,0,0,6" />

								<TextBlock Grid.Row="1" Grid.Column="0" Text="{markup:Localize AboutJiraFormat}"
										  FontSize="12"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="1" Grid.Column="1" Text="{markup:Localize AboutJiraFormatDesc}"
										  FontSize="12" Margin="0,0,0,6" />

								<TextBlock Grid.Row="2" Grid.Column="0" Text="{markup:Localize Favorites}"
										  FontSize="12"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="2" Grid.Column="1" Text="{markup:Localize AboutFavoritesDesc}"
										  FontSize="12" Margin="0,0,0,6" />

								<TextBlock Grid.Row="3" Grid.Column="0" Text="{markup:Localize AboutSubmitWorklogs}"
										  FontSize="12"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="3" Grid.Column="1" Text="{markup:Localize AboutSubmitWorklogsDesc}"
										  FontSize="12" Margin="0,0,0,6" />

								<TextBlock Grid.Row="4" Grid.Column="0" Text="{markup:Localize AboutSystemTray}"
										  FontSize="12"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,6" />
								<TextBlock Grid.Row="4" Grid.Column="1" Text="{markup:Localize AboutSystemTrayDesc}"
										  FontSize="12" Margin="0,0,0,6" />
							</Grid>

							<Separator Margin="0,14" />

							<!-- System -->
							<TextBlock Text="{markup:Localize SystemInfo}"
									  FontSize="14"
									  FontWeight="Medium"
									  Margin="0,0,0,10" />

							<Grid>
								<Grid.ColumnDefinitions>
									<ColumnDefinition Width="100" />
									<ColumnDefinition Width="*" />
								</Grid.ColumnDefinitions>
								<Grid.RowDefinitions>
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
									<RowDefinition Height="Auto" />
								</Grid.RowDefinitions>

								<TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:Localize Runtime}"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,8" />
								<TextBlock Grid.Row="0" Grid.Column="1"
										  Text="{Binding RuntimeVersion}"
										  Margin="0,0,0,8" />

								<TextBlock Grid.Row="1" Grid.Column="0" Text="{markup:Localize PlatformLabel}"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
										  Margin="0,0,0,8" />
								<TextBlock Grid.Row="1" Grid.Column="1"
										  Text="{Binding PlatformInfo}"
										  Margin="0,0,0,8" />

								<TextBlock Grid.Row="2" Grid.Column="0" Text="{markup:Localize UIFramework}"
										  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}" />
								<TextBlock Grid.Row="2" Grid.Column="1"
										  Text="WPF" />
							</Grid>

							<Separator Margin="0,14" />

							<TextBlock FontSize="11"
									  Foreground="{DynamicResource MaterialDesign.Brush.Foreground.Light}"
									  TextWrapping="Wrap"
									  FontStyle="Italic"
									  HorizontalAlignment="Center"
									  Opacity="0.7"
									  Text="{markup:Localize AboutQuote}" />
						</StackPanel>
					</ScrollViewer>
				</TabItem>
			</TabControl>

			<!-- Action Buttons -->
			<Border Grid.Row="2"
				   Background="{DynamicResource MaterialDesign.Brush.Background.Light}"
				   BorderBrush="{DynamicResource MaterialDesign.Brush.Border}"
				   BorderThickness="0,1,0,0"
				   Padding="24,16"
				   CornerRadius="0,0,8,8">
				<StackPanel Orientation="Horizontal"
						   HorizontalAlignment="Right">
					<Button Content="{markup:Localize Cancel}"
						   Style="{StaticResource SecondaryButtonStyle}"
						   Command="{Binding CancelCommand}"
						   Margin="0,0,8,0"
						   Width="100" />
					<Button Content="{markup:Localize Save}"
						   Style="{StaticResource PrimaryButtonStyle}"
						   Command="{Binding SaveCommand}"
						   Width="100" />
				</StackPanel>
			</Border>
		</Grid>
	</Border>
</Window>