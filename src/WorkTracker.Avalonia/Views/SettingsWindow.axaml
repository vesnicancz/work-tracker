<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:markup="using:WorkTracker.Avalonia.Markup"
        xmlns:vm="using:WorkTracker.Avalonia.ViewModels"
        xmlns:shared="using:WorkTracker.UI.Shared.ViewModels"
        x:Class="WorkTracker.Avalonia.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        mc:Ignorable="d"
        Title="{markup:Localize Settings}"
        Width="640"
        Height="700"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent">

    <Border CornerRadius="{DynamicResource WindowCornerRadius}"
            Background="{DynamicResource DialogBackground}"
            BorderBrush="{DynamicResource SeparatorColor}"
            BorderThickness="1"
            BoxShadow="0 4 24 0 #40000000"
            ClipToBounds="True"
            Margin="8"
            x:Name="DialogBorder">

        <Grid RowDefinitions="Auto,*">

            <!-- Dialog titlebar -->
            <Border Grid.Row="0" x:Name="DialogTitleBar"
                    Background="{DynamicResource TitleBarBackground}"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="{DynamicResource TitleBarBorderThickness}"
                    CornerRadius="{DynamicResource WindowTopCornerRadius}"
                    Height="36"
                    IsVisible="{DynamicResource ShowDialogTitleBar}">
                <Panel>
                    <TextBlock Text="{markup:Localize Settings}" FontSize="12"
                               Foreground="{DynamicResource AppTitleForeground}"
                               HorizontalAlignment="{DynamicResource TitleBarAlignment}"
                               VerticalAlignment="Center"
                               Margin="12,0,12,0" />
                    <Button x:Name="CloseButton"
                            Width="36" Height="28" Padding="0"
                            Background="Transparent" BorderThickness="0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,6,0"
                            ToolTip.Tip="{markup:Localize Close}">
                        <material:MaterialIcon Kind="Close"
                                              Width="{DynamicResource WindowControlIconSize}"
                                              Height="{DynamicResource WindowControlIconSize}"
                                              Foreground="{DynamicResource WindowControlForeground}" />
                    </Button>
                </Panel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1" RowDefinitions="*,Auto">

                <TabControl Grid.Row="0" Margin="0,4,0,0">

                    <!-- ===== General ===== -->
                    <TabItem Header="{markup:Localize General}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="20,12" Spacing="0">

                                <TextBlock Text="{markup:Localize WindowBehavior}" FontSize="13" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8" />

                                <RadioButton IsChecked="{Binding IsMinimizeToTray}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Localize MinimizeToTray}" FontWeight="Medium" />
                                        <TextBlock Text="{markup:Localize MinimizeToTrayDesc}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </RadioButton>

                                <RadioButton IsChecked="{Binding IsExitApplication}">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Localize ExitApplication}" FontWeight="Medium" />
                                        <TextBlock Text="{markup:Localize ExitApplicationDesc}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </RadioButton>

                                <Separator Margin="0,16" />

                                <TextBlock Text="{markup:Localize Startup}" FontSize="13" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8" />

                                <CheckBox IsChecked="{Binding StartWithWindows}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Localize StartWithWindows}" FontWeight="Medium" />
                                        <TextBlock Text="{markup:Localize StartWithWindowsDesc}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </CheckBox>

                                <CheckBox IsChecked="{Binding StartMinimized}">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Localize StartMinimized}" FontWeight="Medium" />
                                        <TextBlock Text="{markup:Localize StartMinimizedDesc}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </CheckBox>

                                <Separator Margin="0,16" />

                                <TextBlock Text="{markup:Localize Appearance}" FontSize="13" Foreground="{DynamicResource TextMuted}"
                                           Margin="0,0,0,8" />

                                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                                    <TextBlock Text="{markup:Localize Theme}" FontWeight="Medium" VerticalAlignment="Center" />
                                    <ComboBox SelectedItem="{Binding SelectedTheme}"
                                              ItemsSource="{Binding AvailableThemes}"
                                              MinWidth="150" />
                                </StackPanel>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Favorites ===== -->
                    <TabItem Header="{markup:Localize Favorites}">
                        <Grid Margin="20,12" RowDefinitions="*,Auto">

                            <!-- Two-column: list | edit -->
                            <Grid Grid.Row="0" ColumnDefinitions="*,12,*">

                                <!-- List -->
                                <Border Grid.Column="0"
                                        Background="{DynamicResource SidebarBackground}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="4">
                                    <Grid RowDefinitions="*,Auto">
                                        <ListBox Grid.Row="0"
                                                 ItemsSource="{Binding FavoriteWorkItems}"
                                                 SelectedItem="{Binding SelectedFavorite}"
                                                 Background="Transparent">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="6,3" Spacing="1">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <material:MaterialIcon Kind="Star" Width="14" Height="14"
                                                                                  Foreground="Gold"
                                                                                  VerticalAlignment="Center"
                                                                                  IsVisible="{Binding !ShowAsTemplate}" />
                                                            <material:MaterialIcon Kind="SquareEditOutline" Width="14" Height="14"
                                                                                  Foreground="DodgerBlue"
                                                                                  VerticalAlignment="Center"
                                                                                  IsVisible="{Binding ShowAsTemplate}" />
                                                            <TextBlock Text="{Binding Name}" FontWeight="Medium" FontSize="13"
                                                                       VerticalAlignment="Center" />
                                                        </StackPanel>
                                                        <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" Margin="20,0,0,0">
                                                            <Run Text="{Binding TicketId, TargetNullValue='(no ticket)'}" />
                                                            <Run Text=" - " />
                                                            <Run Text="{Binding Description, TargetNullValue='(no description)'}" />
                                                        </TextBlock>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>

                                        <!-- List toolbar: Remove + Move Up/Down -->
                                        <StackPanel Grid.Row="1" Orientation="Horizontal"
                                                    HorizontalAlignment="Right" Margin="6" Spacing="2">
                                            <Button Command="{Binding RemoveFavoriteCommand}"
                                                    Width="28" Height="28" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    ToolTip.Tip="{markup:Localize RemoveFavorite}">
                                                <material:MaterialIcon Kind="Delete" Width="16" Height="16"
                                                                      Foreground="{DynamicResource DangerRed}" />
                                            </Button>
                                            <Button Command="{Binding MoveFavoriteUpCommand}"
                                                    Width="28" Height="28" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    ToolTip.Tip="{markup:Localize MoveUp}">
                                                <material:MaterialIcon Kind="ArrowUp" Width="16" Height="16"
                                                                      Foreground="{DynamicResource TextMuted}" />
                                            </Button>
                                            <Button Command="{Binding MoveFavoriteDownCommand}"
                                                    Width="28" Height="28" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    ToolTip.Tip="{markup:Localize MoveDown}">
                                                <material:MaterialIcon Kind="ArrowDown" Width="16" Height="16"
                                                                      Foreground="{DynamicResource TextMuted}" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Placeholder when no favorite selected -->
                                <TextBlock Grid.Column="2"
                                           Text="{markup:Localize SelectFavoriteToEdit}"
                                           Foreground="{DynamicResource TextMuted}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           FontSize="12"
                                           IsVisible="{Binding !IsEditFormVisible}" />

                                <!-- Edit form -->
                                <Border Grid.Column="2"
                                        Background="{DynamicResource SidebarBackground}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1"
                                        CornerRadius="4" Padding="14"
                                        IsVisible="{Binding IsEditFormVisible}">
                                    <StackPanel Spacing="8">
                                        <!-- Form header indicating mode -->
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                   Text="{markup:Localize EditFavorite}"
                                                   IsVisible="{Binding !IsAddingFavorite}" />
                                        <TextBlock FontSize="12" Foreground="{DynamicResource TextMuted}"
                                                   Text="{markup:Localize NewFavorite}"
                                                   IsVisible="{Binding IsAddingFavorite}" />

                                        <TextBox Text="{Binding EditingFavoriteName, Mode=TwoWay}"
                                                 Watermark="{markup:Localize FavoriteName}" FontSize="12" />
                                        <TextBox Text="{Binding EditingFavoriteTicket, Mode=TwoWay}"
                                                 Watermark="{markup:Localize FavoriteTicket}" FontSize="12" />
                                        <TextBox Text="{Binding EditingFavoriteDescription, Mode=TwoWay}"
                                                 Watermark="{markup:Localize FavoriteDescription}"
                                                 FontSize="12" TextWrapping="Wrap"
                                                 AcceptsReturn="True" MinHeight="50" />

                                        <!-- Show as template checkbox -->
                                        <CheckBox IsChecked="{Binding EditingFavoriteShowAsTemplate}" Margin="0,4,0,0">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{markup:Localize FavoriteShowAsTemplate}" FontSize="12" FontWeight="Medium" />
                                                <TextBlock Text="{markup:Localize FavoriteShowAsTemplateDesc}"
                                                           FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </CheckBox>

                                        <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right">
                                            <Button Command="{Binding CancelEditFavoriteCommand}"
                                                    Background="Transparent" BorderThickness="0" Padding="8,6">
                                                <TextBlock Text="{markup:Localize Cancel}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                                            </Button>
                                            <Button Command="{Binding SaveFavoriteCommand}"
                                                    Padding="8,6" Classes="accent">
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <material:MaterialIcon Kind="ContentSave" Width="14" Height="14" />
                                                    <TextBlock Text="{markup:Localize Save}" FontSize="12" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                            </Grid>

                            <!-- Add button -->
                            <Button Grid.Row="1"
                                    Command="{Binding AddFavoriteCommand}"
                                    Background="Transparent" BorderThickness="0"
                                    Padding="8,6" Margin="0,8,0,0"
                                    HorizontalAlignment="Left">
                                <StackPanel Orientation="Horizontal" Spacing="4">
                                    <material:MaterialIcon Kind="Plus" Width="14" Height="14"
                                                          Foreground="{DynamicResource TextMuted}" />
                                    <TextBlock Text="{markup:Localize AddFavorite}" FontSize="12" Foreground="{DynamicResource TextSecondary}" />
                                </StackPanel>
                            </Button>

                        </Grid>
                    </TabItem>

                    <!-- ===== Pomodoro ===== -->
                    <TabItem Header="{markup:Localize Pomodoro}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="20,12">
                                <TextBlock Text="{markup:Localize Pomodoro}"
                                           FontSize="15" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBright}"
                                           Margin="0,0,0,10" />

                                <CheckBox IsChecked="{Binding PomodoroEnabled}" Margin="0,0,0,6">
                                    <StackPanel>
                                        <TextBlock Text="{markup:Localize PomodoroEnabled}" FontWeight="Medium" />
                                        <TextBlock Text="{markup:Localize PomodoroEnabledDesc}"
                                                   Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                    </StackPanel>
                                </CheckBox>

                                <Separator Margin="0,16" />

                                <StackPanel IsEnabled="{Binding PomodoroEnabled}">
                                    <StackPanel Margin="0,0,0,8" Spacing="3">
                                        <TextBlock Text="{markup:Localize PomodoroWorkMinutes}" FontSize="12" FontWeight="Medium" />
                                        <TextBox Text="{Binding PomodoroWorkMinutes}" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8" Spacing="3">
                                        <TextBlock Text="{markup:Localize PomodoroShortBreakMinutes}" FontSize="12" FontWeight="Medium" />
                                        <TextBox Text="{Binding PomodoroShortBreakMinutes}" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8" Spacing="3">
                                        <TextBlock Text="{markup:Localize PomodoroLongBreakMinutes}" FontSize="12" FontWeight="Medium" />
                                        <TextBox Text="{Binding PomodoroLongBreakMinutes}" FontSize="12" />
                                    </StackPanel>

                                    <StackPanel Margin="0,0,0,8" Spacing="3">
                                        <TextBlock Text="{markup:Localize PomodorosBeforeLongBreak}" FontSize="12" FontWeight="Medium" />
                                        <TextBox Text="{Binding PomodorosBeforeLongBreak}" FontSize="12" />
                                    </StackPanel>

                                    <Separator Margin="0,16" />

                                    <CheckBox IsChecked="{Binding PomodoroAutoStartTracking}" Margin="0,0,0,6">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Localize PomodoroAutoStartTracking}" FontWeight="Medium" />
                                            <TextBlock Text="{markup:Localize PomodoroAutoStartTrackingDesc}"
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </CheckBox>

                                    <CheckBox IsChecked="{Binding PomodoroAutoStopTracking}">
                                        <StackPanel>
                                            <TextBlock Text="{markup:Localize PomodoroAutoStopTracking}" FontWeight="Medium" />
                                            <TextBlock Text="{markup:Localize PomodoroAutoStopTrackingDesc}"
                                                       Foreground="{DynamicResource TextMuted}" FontSize="11" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </CheckBox>

                                </StackPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== Plugins ===== -->
                    <TabItem Header="{markup:Localize Plugins}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="20,12" Spacing="10">

                                <ComboBox ItemsSource="{Binding Plugins}"
                                          SelectedItem="{Binding SelectedPlugin}"
                                          DisplayMemberBinding="{ReflectionBinding Name}"
                                          HorizontalAlignment="Stretch"
                                          PlaceholderText="{markup:Localize SelectPlugin}" />

                                <Border Background="{DynamicResource SidebarBackground}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1" CornerRadius="4" Padding="14">
                                    <StackPanel Spacing="10">

                                        <CheckBox IsChecked="{Binding SelectedPlugin.IsEnabled}"
                                                  Content="{markup:Localize EnablePlugin}" />

                                        <Separator />

                                        <!-- Metadata -->
                                        <Grid ColumnDefinitions="80,*" RowDefinitions="Auto,Auto,Auto"
                                              Margin="0,0,0,4">
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:Localize PluginVersion}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedPlugin.Version}" FontSize="12" Margin="0,0,0,4" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="{markup:Localize PluginAuthor}" Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,4" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedPlugin.Author}" FontSize="12" Margin="0,0,0,4" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="{markup:Localize PluginDescription}" Foreground="{DynamicResource TextMuted}" FontSize="12" VerticalAlignment="Top" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedPlugin.Description}" FontSize="12" TextWrapping="Wrap" />
                                        </Grid>

                                        <Separator />

                                        <TextBlock Text="{markup:Localize Configuration}" FontSize="12" Foreground="{DynamicResource TextMuted}" />

                                        <!-- Config fields -->
                                        <ItemsControl ItemsSource="{Binding SelectedPlugin.ConfigurationFields}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="shared:ConfigurationFieldViewModel">
                                                    <StackPanel Margin="0,0,0,8" Spacing="3">
                                                        <TextBlock Text="{Binding Label}" FontSize="12" FontWeight="Medium" />
                                                        <TextBox Text="{Binding Value, Mode=TwoWay}"
                                                                 Watermark="{Binding Placeholder}"
                                                                 FontSize="12" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <!-- Test Connection -->
                                        <Button IsVisible="{Binding SelectedPlugin.SupportsTestConnection}"
                                                Command="{Binding TestConnectionCommand}"
                                                Background="Transparent" Padding="10,6"
                                                BorderBrush="{DynamicResource CardBorder}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <material:MaterialIcon Kind="LanConnect" Width="16" Height="16"
                                                                      Foreground="{DynamicResource TextMuted}" />
                                                <TextBlock Text="{markup:Localize TestConnection}" FontSize="12"
                                                           Foreground="{DynamicResource TextSecondary}" />
                                            </StackPanel>
                                        </Button>

                                        <TextBlock Text="{Binding TestConnectionResult}"
                                                   FontSize="12" TextWrapping="Wrap" />

                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                    <!-- ===== About ===== -->
                    <TabItem Header="{markup:Localize About}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <StackPanel Margin="20,12" Spacing="14">

                                <StackPanel Spacing="4">
                                    <TextBlock Text="{markup:Localize WorkTracker}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AppVersionDisplay}"
                                               FontSize="13" Foreground="{DynamicResource TextMuted}" />
                                </StackPanel>

                                <Separator />

                                <!-- Keyboard Shortcuts -->
                                <TextBlock Text="{markup:Localize KeyboardShortcuts}" FontSize="13" FontWeight="SemiBold" />

                                <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto" Margin="0,0,0,4">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + Shift + W"
                                               FontSize="12" FontFamily="Consolas"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutGlobalHotkeyDesc}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Enter"
                                               FontSize="12" FontFamily="Consolas"
                                               Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutEnterKeyDesc}" />
                                </Grid>

                                <Separator />

                                <!-- Quick Reference -->
                                <TextBlock Text="{markup:Localize QuickReference}" FontSize="13" FontWeight="SemiBold" />

                                <Grid ColumnDefinitions="130,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="0,0,0,4">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:Localize AboutStartTracking}"
                                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="0" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutStartTrackingDesc}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{markup:Localize AboutJiraFormat}"
                                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutJiraFormatDesc}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{markup:Localize Favorites}"
                                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutFavoritesDesc}" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{markup:Localize AboutSubmitWorklogs}"
                                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutSubmitWorklogsDesc}" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="{markup:Localize AboutSystemTray}"
                                               FontSize="12" Foreground="{DynamicResource TextMuted}" Margin="0,0,0,4" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" FontSize="12" Margin="0,0,0,4"
                                               Text="{markup:Localize AboutSystemTrayDesc}" />
                                </Grid>

                                <Separator />

                                <!-- System Info -->
                                <TextBlock Text="{markup:Localize SystemInfo}" FontSize="13" FontWeight="SemiBold" />

                                <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto,Auto" Margin="0,0,0,4">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{markup:Localize Runtime}"
                                               Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="0" Grid.Column="1"
                                               Text="{Binding RuntimeVersion}"
                                               FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{markup:Localize PlatformLabel}"
                                               Foreground="{DynamicResource TextMuted}" FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding PlatformInfo}"
                                               FontSize="12" Margin="0,0,0,6" />
                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{markup:Localize UIFramework}"
                                               Foreground="{DynamicResource TextMuted}" FontSize="12" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Avalonia"
                                               FontSize="12" />
                                </Grid>


                                <Separator />

                                <TextBlock FontSize="11" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap"
                                           FontStyle="Italic" HorizontalAlignment="Center" Opacity="0.7"
                                           Text="{markup:Localize AboutQuote}" />

                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

                </TabControl>

                <!-- Bottom bar -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Spacing="8" Margin="20,0,20,14">
                    <Button Content="{markup:Localize Cancel}"
                            Command="{Binding CancelCommand}"
                            Padding="20,8"
                            Background="{DynamicResource ButtonSecondaryBg}"
                            Foreground="{DynamicResource ButtonSecondaryFg}" />
                    <Button Command="{Binding SaveCommand}"
                            Padding="20,8"
                            Classes="accent">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <material:MaterialIcon Kind="ContentSave" Width="16" Height="16" />
                            <TextBlock Text="{markup:Localize Save}" FontWeight="SemiBold" />
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>

        </Grid>
    </Border>
</Window>
