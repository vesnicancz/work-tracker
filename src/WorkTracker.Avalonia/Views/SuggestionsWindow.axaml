<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:material="using:Material.Icons.Avalonia"
        xmlns:markup="using:WorkTracker.Avalonia.Markup"
        xmlns:vm="using:WorkTracker.UI.Shared.ViewModels"
        x:Class="WorkTracker.Avalonia.Views.SuggestionsWindow"
        x:DataType="vm:SuggestionsViewModel"
        mc:Ignorable="d"
        Title="{markup:Localize Suggestions}"
        Width="600"
        Height="550"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        SystemDecorations="None"
        Background="Transparent">

    <Border CornerRadius="{DynamicResource WindowCornerRadius}"
            Background="{DynamicResource DialogBackground}"
            BorderBrush="{DynamicResource SeparatorColor}"
            BorderThickness="1"
            BoxShadow="0 4 24 0 #40000000"
            ClipToBounds="True"
            Margin="8">

        <Grid RowDefinitions="Auto,*">

            <!-- Dialog titlebar -->
            <Border Grid.Row="0" x:Name="DialogTitleBar"
                    Background="{DynamicResource TitleBarBackground}"
                    BorderBrush="{DynamicResource SeparatorColor}"
                    BorderThickness="{DynamicResource TitleBarBorderThickness}"
                    CornerRadius="{DynamicResource WindowTopCornerRadius}"
                    Height="36"
                    IsVisible="{DynamicResource ShowDialogTitleBar}">
                <Panel>
                    <TextBlock Text="{markup:Localize Suggestions}" FontSize="12"
                               Foreground="{DynamicResource AppTitleForeground}"
                               HorizontalAlignment="{DynamicResource TitleBarAlignment}"
                               VerticalAlignment="Center"
                               Margin="12,0,12,0" />

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,6,0" Spacing="0">
                        <Button Command="{Binding RefreshCommand}"
                                Width="36" Height="28" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTip.Tip="{markup:Localize Refresh}">
                            <material:MaterialIcon Kind="Refresh"
                                                  Width="{DynamicResource WindowControlIconSize}"
                                                  Height="{DynamicResource WindowControlIconSize}"
                                                  Foreground="{DynamicResource WindowControlForeground}" />
                        </Button>
                        <Button x:Name="CloseButton"
                                Width="36" Height="28" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                ToolTip.Tip="{markup:Localize Close}">
                            <material:MaterialIcon Kind="Close"
                                                  Width="{DynamicResource WindowControlIconSize}"
                                                  Height="{DynamicResource WindowControlIconSize}"
                                                  Foreground="{DynamicResource WindowControlForeground}" />
                        </Button>
                    </StackPanel>
                </Panel>
            </Border>

            <!-- Content -->
            <Grid Grid.Row="1">
                <!-- Groups -->
                <ScrollViewer x:Name="ContentScroll"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Groups}"
                                  x:CompileBindings="False"
                                  Margin="16,12">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Spacing="6" Margin="0,0,0,16">
                                    <!-- Group header -->
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBright}">
                                            <Run Text="{Binding Name}" />
                                            <Run Text=" (" /><Run Text="{Binding Count}" /><Run Text=")" />
                                        </TextBlock>
                                        <ProgressBar IsIndeterminate="True" Width="60" Height="2"
                                                     VerticalAlignment="Center"
                                                     IsVisible="{Binding IsSearching}" />
                                    </StackPanel>

                                    <!-- Error -->
                                    <TextBlock Text="{Binding Error}"
                                               Foreground="{DynamicResource ErrorColor}"
                                               FontSize="12" TextWrapping="Wrap"
                                               IsVisible="{Binding HasError}"
                                               Margin="0,0,0,4" />

                                    <!-- Search box (only for plugins that support it) -->
                                    <TextBox Text="{Binding SearchText, Mode=TwoWay}"
                                             Watermark="{markup:Localize SearchSuggestions}"
                                             IsVisible="{Binding SupportsSearch}"
                                             Margin="0,0,0,4" />

                                    <!-- Items -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Command="{Binding $parent[ItemsControl].DataContext.SelectCommand}"
                                                        CommandParameter="{Binding}"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Stretch"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="6,5" Margin="0,1">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <StackPanel Grid.Column="0" Spacing="1">
                                                            <TextBlock Text="{Binding DisplayText}"
                                                                       FontSize="12" FontWeight="Medium"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       Foreground="{DynamicResource TextBright}" />
                                                            <TextBlock Text="{Binding TimeDisplay}"
                                                                       FontSize="11"
                                                                       Foreground="{DynamicResource TextMuted}"
                                                                       IsVisible="{Binding HasTimeSlot}" />
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Source}"
                                                                   FontSize="10" Opacity="0.5"
                                                                   Foreground="{DynamicResource TextMuted}"
                                                                   VerticalAlignment="Center"
                                                                   Margin="8,0,0,0" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Loading overlay -->
                <ProgressBar IsIndeterminate="True" Height="2"
                             VerticalAlignment="Top"
                             IsVisible="{Binding IsLoading}" />
            </Grid>
        </Grid>
    </Border>
</Window>
