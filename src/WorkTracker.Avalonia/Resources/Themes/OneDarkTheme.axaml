<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Palette: One Dark Pro
        Flat ResourceDictionary — no ThemeDictionaries.
        Loaded at runtime via MergedDictionaries.
    -->

    <!-- Background / Surface -->
    <SolidColorBrush x:Key="AppBackground"       Color="#282c34" />
    <SolidColorBrush x:Key="SidebarBackground"   Color="#21252b" />
    <SolidColorBrush x:Key="SidebarBorder"       Color="#181a1f" />
    <SolidColorBrush x:Key="CardBackground"      Color="#2c313c" />
    <SolidColorBrush x:Key="CardBorder"          Color="#3e4452" />
    <SolidColorBrush x:Key="InputBackground"     Color="#1d1f23" />
    <SolidColorBrush x:Key="InputBorder"         Color="#3e4452" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary"         Color="#abb2bf" />
    <SolidColorBrush x:Key="TextSecondary"       Color="#9da5b4" />
    <SolidColorBrush x:Key="TextMuted"           Color="#636d83" />
    <SolidColorBrush x:Key="TextBright"          Color="#d7dae0" />

    <!-- Accent / Status -->
    <SolidColorBrush x:Key="AccentBlue"          Color="#61afef" />
    <SolidColorBrush x:Key="AccentBlueDark"      Color="#4d9de0" />
    <SolidColorBrush x:Key="AccentBluePressed"   Color="#3a8ad0" />
    <SolidColorBrush x:Key="SuccessGreen"        Color="#98c379" />
    <SolidColorBrush x:Key="SuccessGreenDark"    Color="#7fb365" />
    <SolidColorBrush x:Key="SuccessGreenPressed" Color="#6a9a54" />
    <SolidColorBrush x:Key="DangerRed"           Color="#e06c75" />
    <SolidColorBrush x:Key="DangerRedDark"       Color="#c95961" />
    <SolidColorBrush x:Key="DangerRedPressed"    Color="#b34a52" />
    <SolidColorBrush x:Key="WarningYellow"       Color="#e5c07b" />
    <SolidColorBrush x:Key="InfoBlue"            Color="#61afef" />
    <SolidColorBrush x:Key="SeparatorColor"      Color="#3e4452" />

    <!-- Active tracking card (green-tinted surface) -->
    <SolidColorBrush x:Key="ActiveCardBackground" Color="#1e2a1e" />
    <SolidColorBrush x:Key="ActiveCardBorder"     Color="#3d5c3d" />

    <!-- Button -->
    <SolidColorBrush x:Key="ButtonSecondaryBg"   Color="#2c313c" />
    <SolidColorBrush x:Key="ButtonSecondaryFg"   Color="#abb2bf" />
    <SolidColorBrush x:Key="AccentButtonFg"      Color="#282c34" />

    <!-- Avalonia system overrides -->
    <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush"           Color="#282c34" />
    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush"          Color="#282c34" />
    <SolidColorBrush x:Key="LayerFillColorDefaultBrush"                   Color="#282c34" />
    <SolidColorBrush x:Key="LayerOnMicaBaseAltFillColorDefaultBrush"      Color="#21252b" />
    <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"          Color="#2c313c" />
    <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"                  Color="#3e4452" />
    <SolidColorBrush x:Key="ControlFillColorDefaultBrush"                 Color="#1d1f23" />
    <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"               Color="#2c313a" />
    <SolidColorBrush x:Key="ControlFillColorTertiaryBrush"                Color="#323842" />
    <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush"               Color="#3e4452" />
    <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush"             Color="#3e4452" />
    <SolidColorBrush x:Key="TextFillColorPrimaryBrush"                    Color="#abb2bf" />
    <SolidColorBrush x:Key="TextFillColorSecondaryBrush"                  Color="#9da5b4" />
    <SolidColorBrush x:Key="TextFillColorTertiaryBrush"                   Color="#636d83" />
    <SolidColorBrush x:Key="TextFillColorDisabledBrush"                   Color="#4b5263" />
    <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"               Color="#3e4452" />
    <Color x:Key="SystemAccentColor">#61afef</Color>
    <Color x:Key="SystemAccentColorLight1">#7fbfef</Color>
    <Color x:Key="SystemAccentColorLight2">#a0d0f5</Color>
    <Color x:Key="SystemAccentColorDark1">#4d9de0</Color>
    <Color x:Key="SystemAccentColorDark2">#3a8ad0</Color>
    <SolidColorBrush x:Key="SuccessBrush"    Color="#98c379" />
    <SolidColorBrush x:Key="WarningBrush"    Color="#e5c07b" />
    <SolidColorBrush x:Key="ErrorBrush"      Color="#e06c75" />
    <SolidColorBrush x:Key="InfoBrush"       Color="#61afef" />

    <!-- Extended layout parameters -->
    <CornerRadius x:Key="CardCornerRadius">4</CornerRadius>
    <Thickness x:Key="CardPadding">14</Thickness>

    <!-- Window chrome -->
    <SolidColorBrush x:Key="TitleBarBackground" Color="#21252b" />
    <Thickness x:Key="TitleBarBorderThickness">0,0,0,1</Thickness>
    <CornerRadius x:Key="WindowCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="WindowTopCornerRadius">8,8,0,0</CornerRadius>
    <CornerRadius x:Key="SidebarCornerRadius">0,0,0,8</CornerRadius>
    <Thickness x:Key="SidebarMargin">0</Thickness>
    <Thickness x:Key="SidebarBorderThickness">0,0,1,0</Thickness>
    <SolidColorBrush x:Key="DialogBackground" Color="#21252b" />
    <SolidColorBrush x:Key="WindowControlForeground" Color="#9da5b4" />
    <SolidColorBrush x:Key="AppTitleForeground"      Color="#636d83" />
    <x:Double x:Key="WindowControlIconSize">14</x:Double>
    <x:Double x:Key="ToolbarIconSize">16</x:Double>
    <HorizontalAlignment x:Key="TitleBarAlignment">Left</HorizontalAlignment>
    <x:Boolean x:Key="ShowDialogTitleBar">True</x:Boolean>
    <Thickness x:Key="ToasterMargin">0,0,0,12</Thickness>
    <x:Double x:Key="RowActionsDefaultOpacity">1</x:Double>
    <SolidColorBrush x:Key="RowActionPlayColor" Color="#9da5b4" />
    <SolidColorBrush x:Key="RowActionEditColor" Color="#9da5b4" />
    <SolidColorBrush x:Key="RowActionDeleteColor" Color="#9da5b4" />

</ResourceDictionary>
