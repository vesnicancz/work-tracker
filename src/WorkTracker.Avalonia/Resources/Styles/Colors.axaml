<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--
        Palette: One Dark Pro (Dark) / One Light (Light)
        Switchable via Application.RequestedThemeVariant or runtime ThemeVariant toggle.
    -->

    <ResourceDictionary.ThemeDictionaries>

        <!-- ══════════════════════════════════════════════════════════ DARK ══ -->
        <ResourceDictionary x:Key="Dark">

            <!-- Background / Surface -->
            <SolidColorBrush x:Key="AppBackground"       Color="#282c34" />
            <SolidColorBrush x:Key="SidebarBackground"   Color="#21252b" />
            <SolidColorBrush x:Key="SidebarBorder"       Color="#181a1f" />
            <SolidColorBrush x:Key="CardBackground"      Color="#2c313c" />
            <SolidColorBrush x:Key="CardBorder"          Color="#3e4452" />
            <SolidColorBrush x:Key="InputBackground"     Color="#1d1f23" />
            <SolidColorBrush x:Key="InputBorder"         Color="#3e4452" />

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimary"         Color="#abb2bf" />
            <SolidColorBrush x:Key="TextSecondary"       Color="#9da5b4" />
            <SolidColorBrush x:Key="TextMuted"           Color="#636d83" />
            <SolidColorBrush x:Key="TextBright"          Color="#d7dae0" />

            <!-- Accent / Status -->
            <SolidColorBrush x:Key="AccentBlue"          Color="#61afef" />
            <SolidColorBrush x:Key="AccentBlueDark"      Color="#4d9de0" />
            <SolidColorBrush x:Key="AccentBluePressed"   Color="#3a8ad0" />
            <SolidColorBrush x:Key="SuccessGreen"        Color="#98c379" />
            <SolidColorBrush x:Key="SuccessGreenDark"    Color="#7fb365" />
            <SolidColorBrush x:Key="SuccessGreenPressed" Color="#6a9a54" />
            <SolidColorBrush x:Key="DangerRed"           Color="#e06c75" />
            <SolidColorBrush x:Key="DangerRedDark"       Color="#c95961" />
            <SolidColorBrush x:Key="DangerRedPressed"    Color="#b34a52" />
            <SolidColorBrush x:Key="WarningYellow"       Color="#e5c07b" />
            <SolidColorBrush x:Key="InfoBlue"            Color="#61afef" />
            <SolidColorBrush x:Key="SeparatorColor"      Color="#3e4452" />

            <!-- Active tracking card (green-tinted surface) -->
            <SolidColorBrush x:Key="ActiveCardBackground" Color="#1e2a1e" />
            <SolidColorBrush x:Key="ActiveCardBorder"     Color="#3d5c3d" />

            <!-- Button -->
            <SolidColorBrush x:Key="ButtonSecondaryBg"   Color="#2c313c" />
            <SolidColorBrush x:Key="ButtonSecondaryFg"   Color="#abb2bf" />
            <SolidColorBrush x:Key="AccentButtonFg"      Color="#282c34" />

            <!-- Avalonia system overrides -->
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush"           Color="#282c34" />
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush"          Color="#282c34" />
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"                   Color="#282c34" />
            <SolidColorBrush x:Key="LayerOnMicaBaseAltFillColorDefaultBrush"      Color="#21252b" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"          Color="#2c313c" />
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"                  Color="#3e4452" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"                 Color="#1d1f23" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"               Color="#2c313a" />
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush"                Color="#323842" />
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush"               Color="#3e4452" />
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush"             Color="#3e4452" />
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"                    Color="#abb2bf" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"                  Color="#9da5b4" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"                   Color="#636d83" />
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"                   Color="#4b5263" />
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"               Color="#3e4452" />
            <Color x:Key="SystemAccentColor">#61afef</Color>
            <Color x:Key="SystemAccentColorLight1">#7fbfef</Color>
            <Color x:Key="SystemAccentColorLight2">#a0d0f5</Color>
            <Color x:Key="SystemAccentColorDark1">#4d9de0</Color>
            <Color x:Key="SystemAccentColorDark2">#3a8ad0</Color>
            <SolidColorBrush x:Key="SuccessBrush"    Color="#98c379" />
            <SolidColorBrush x:Key="WarningBrush"    Color="#e5c07b" />
            <SolidColorBrush x:Key="ErrorBrush"      Color="#e06c75" />
            <SolidColorBrush x:Key="InfoBrush"       Color="#61afef" />

        </ResourceDictionary>

        <!-- ═════════════════════════════════════════════════════════ LIGHT ══ -->
        <ResourceDictionary x:Key="Light">

            <!-- Background / Surface -->
            <SolidColorBrush x:Key="AppBackground"       Color="#ffffff" />
            <SolidColorBrush x:Key="SidebarBackground"   Color="#f0f1f4" />
            <SolidColorBrush x:Key="SidebarBorder"       Color="#d4d6dc" />
            <SolidColorBrush x:Key="CardBackground"      Color="#f8f8fa" />
            <SolidColorBrush x:Key="CardBorder"          Color="#d4d6dc" />
            <SolidColorBrush x:Key="InputBackground"     Color="#ffffff" />
            <SolidColorBrush x:Key="InputBorder"         Color="#c0c4cc" />

            <!-- Text -->
            <SolidColorBrush x:Key="TextPrimary"         Color="#383a42" />
            <SolidColorBrush x:Key="TextSecondary"       Color="#6b7280" />
            <SolidColorBrush x:Key="TextMuted"           Color="#9ca3af" />
            <SolidColorBrush x:Key="TextBright"          Color="#1f2328" />

            <!-- Accent / Status -->
            <SolidColorBrush x:Key="AccentBlue"          Color="#4078f2" />
            <SolidColorBrush x:Key="AccentBlueDark"      Color="#3468d5" />
            <SolidColorBrush x:Key="AccentBluePressed"   Color="#2a58b8" />
            <SolidColorBrush x:Key="SuccessGreen"        Color="#50a14f" />
            <SolidColorBrush x:Key="SuccessGreenDark"    Color="#428c41" />
            <SolidColorBrush x:Key="SuccessGreenPressed" Color="#357534" />
            <SolidColorBrush x:Key="DangerRed"           Color="#e45649" />
            <SolidColorBrush x:Key="DangerRedDark"       Color="#ca3e38" />
            <SolidColorBrush x:Key="DangerRedPressed"    Color="#b0302a" />
            <SolidColorBrush x:Key="WarningYellow"       Color="#c18401" />
            <SolidColorBrush x:Key="InfoBlue"            Color="#4078f2" />
            <SolidColorBrush x:Key="SeparatorColor"      Color="#d4d6dc" />

            <!-- Active tracking card (green-tinted surface) -->
            <SolidColorBrush x:Key="ActiveCardBackground" Color="#edf7ee" />
            <SolidColorBrush x:Key="ActiveCardBorder"     Color="#81c784" />

            <!-- Button -->
            <SolidColorBrush x:Key="ButtonSecondaryBg"   Color="#e6e7eb" />
            <SolidColorBrush x:Key="ButtonSecondaryFg"   Color="#383a42" />
            <SolidColorBrush x:Key="AccentButtonFg"      Color="#ffffff" />

            <!-- Avalonia system overrides -->
            <SolidColorBrush x:Key="SolidBackgroundFillColorBaseBrush"           Color="#ffffff" />
            <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush"          Color="#ffffff" />
            <SolidColorBrush x:Key="LayerFillColorDefaultBrush"                   Color="#ffffff" />
            <SolidColorBrush x:Key="LayerOnMicaBaseAltFillColorDefaultBrush"      Color="#f0f1f4" />
            <SolidColorBrush x:Key="CardBackgroundFillColorDefaultBrush"          Color="#f8f8fa" />
            <SolidColorBrush x:Key="CardStrokeColorDefaultBrush"                  Color="#d4d6dc" />
            <SolidColorBrush x:Key="ControlFillColorDefaultBrush"                 Color="#ffffff" />
            <SolidColorBrush x:Key="ControlFillColorSecondaryBrush"               Color="#f0f1f4" />
            <SolidColorBrush x:Key="ControlFillColorTertiaryBrush"                Color="#e6e7eb" />
            <SolidColorBrush x:Key="ControlStrokeColorDefaultBrush"               Color="#c0c4cc" />
            <SolidColorBrush x:Key="ControlStrokeColorSecondaryBrush"             Color="#c0c4cc" />
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush"                    Color="#383a42" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush"                  Color="#6b7280" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush"                   Color="#9ca3af" />
            <SolidColorBrush x:Key="TextFillColorDisabledBrush"                   Color="#b8bac0" />
            <SolidColorBrush x:Key="DividerStrokeColorDefaultBrush"               Color="#d4d6dc" />
            <Color x:Key="SystemAccentColor">#4078f2</Color>
            <Color x:Key="SystemAccentColorLight1">#6090f5</Color>
            <Color x:Key="SystemAccentColorLight2">#80aaf8</Color>
            <Color x:Key="SystemAccentColorDark1">#3468d5</Color>
            <Color x:Key="SystemAccentColorDark2">#2a58b8</Color>
            <SolidColorBrush x:Key="SuccessBrush"    Color="#50a14f" />
            <SolidColorBrush x:Key="WarningBrush"    Color="#c18401" />
            <SolidColorBrush x:Key="ErrorBrush"      Color="#e45649" />
            <SolidColorBrush x:Key="InfoBrush"       Color="#4078f2" />

        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

</ResourceDictionary>
